[32m2026-03-12 10:40:47 [info]  response /api/flow_nodes:update?filterByTk=352865042890753[39m method=POST path=/api/flow_nodes:update?filterByTk=352865042890753 res={"status":200} action={"actionName":"update","resourceName":"flow_nodes","params":{"filterByTk":"352865042890753","resourceName":"flow_nodes","actionName":"update","values":{"config":{"dataSource":"main","sql":"UPDATE review_records rm\nSET \n    round = '{{$context.data.round}}',\n\n    total_issues = (SELECT count(*) FROM defects WHERE f_0ipjqjhd3dt = {{$context.data.f_0ipjqjhd3dt}}),\n    \n    eff_indep_issues = (SELECT count(*) FROM defects WHERE f_0ipjqjhd3dt = {{$context.data.f_0ipjqjhd3dt}} AND discovery_stage = '独立评审'),\n    \n    eff_meet_issues = (SELECT count(*) FROM defects WHERE f_0ipjqjhd3dt = {{$context.data.f_0ipjqjhd3dt}} AND discovery_stage = '会议评审'),\n    \n    eff_issue_hour = ROUND((CAST((SELECT count(*) FROM defects WHERE f_0ipjqjhd3dt = COALESCE({{$context.data.f_0ipjqjhd3dt}}, 0)) AS DECIMAL) / NULLIF((rm.workload_indep + rm.workload_joint), 0))::numeric, 2),\n    \n    eff_page_hour = ROUND((CAST(rm.page_count AS DECIMAL) / NULLIF((rm.workload_indep + rm.workload_joint), 0))::numeric, 2),\n\n    review_density = ROUND((CAST((SELECT count(*) FROM defects WHERE f_0ipjqjhd3dt = {{$context.data.f_0ipjqjhd3dt}}) AS DECIMAL) / NULLIF(rm.page_count, 0))::numeric, 2),\n    \n    is_standard = CASE \n        WHEN (CAST((SELECT count(*) FROM defects WHERE f_0ipjqjhd3dt = {{$context.data.f_0ipjqjhd3dt}}) AS DECIMAL) / NULLIF(rm.page_count, 0)) < 0.6 THEN '是' \n        ELSE '否' \n    END,\n    \n    fail_reason = CASE \n        WHEN (CAST((SELECT count(*) FROM defects WHERE f_0ipjqjhd3dt = {{$context.data.f_0ipjqjhd3dt}}) AS DECIMAL) / NULLIF(rm.page_count, 0)) >= 0.6 THEN '缺陷密度超过0.6，建议重新评审' \n        ELSE NULL \n    END\n\nWHERE rm.id = {{$context.data.f_0ipjqjhd3dt}}"}}}} userId=1 username=nocobase status=200 cost=155 app=main reqId=725c93d4-57ed-458e-ad34-684d73d04172 bodySize=1837
