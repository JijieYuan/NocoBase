[32m2026-03-16 17:06:28 [info]  response /api/flow_nodes:update?filterByTk=353638520127488[39m method=POST path=/api/flow_nodes:update?filterByTk=353638520127488 res={"status":200} action={"actionName":"update","resourceName":"flow_nodes","params":{"filterByTk":"353638520127488","resourceName":"flow_nodes","actionName":"update","values":{"config":{"dataSource":"main","sql":"/* 1. 清理汇总表旧数据 */\n-- 使用动态变量替换 456\nDELETE FROM \"defects_reason\" \nWHERE \"review_id\" = {{ $context.data.f_0ipjqjhd3dt }}; \n\n/* 2. 统计并重新插入 */\nINSERT INTO \"defects_reason\" (\n    \"id\",\n    \"createdAt\",\n    \"updatedAt\",\n    \"review_id\",\n    \"module_id\",\n    \"count_requirement\", \n    \"count_design\", \n    \"count_coding\", \n    \"count_package\", \n    \"count_dependency\"\n)\nSELECT \n    -- 动态生成 ID：(当前时间戳 * 1000 + 0-999随机数)\n    (extract(epoch from now()) * 1000 + floor(random() * 1000))::bigint,\n    NOW(),\n    NOW(),\n    t1.\"f_0ipjqjhd3dt\", -- 评审外键\n    t1.\"f_jmazop48q5l\", -- 模块外键\n    SUM(CASE WHEN t1.\"level_1_cause\" = '需求问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '设计问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '编码规范' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '打包问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '依赖问题' THEN 1 ELSE 0 END)\nFROM \"defects\" AS t1\n-- 👈 这里的 456 也要换成动态变量\nWHERE t1.\"f_0ipjqjhd3dt\" = {{ $context.data.f_0ipjqjhd3dt }} \nGROUP BY t1.\"f_jmazop48q5l\", t1.\"f_0ipjqjhd3dt\";"}}}} userId=1 username=nocobase status=200 cost=8 app=main reqId=c76d18c6-953a-4e5d-9a00-dd72137b8eda bodySize=1577
