[32m2026-03-16 16:12:46 [info]  response /api/flow_nodes:update?filterByTk=353631750520833[39m method=POST path=/api/flow_nodes:update?filterByTk=353631750520833 res={"status":200} action={"actionName":"update","resourceName":"flow_nodes","params":{"filterByTk":"353631750520833","resourceName":"flow_nodes","actionName":"update","values":{"config":{"dataSource":"main","sql":"DELETE FROM \"defects_reason\" \nWHERE \"review_id\" = {{ $context.data.id }};\n\n-- 2. 插入时也使用真实列名 review_id\nINSERT INTO \"defects_reason\" (\n    \"review_id\",         -- 对应你截图里的外键\n    \"module_ref_id\",     -- 请确认汇总表里“关联模块”的外键名，如果报错请改为 module_id\n    \"count_requirement\", \n    \"count_design\", \n    \"count_coding\", \n    \"count_package\", \n    \"count_dependency\"\n)\nSELECT \n    '{{ $context.data.id }}'::bigint,\n    \"module_id\",         -- 明细表里关联模块的外键名\n    SUM(CASE WHEN \"level_1_cause\" = '需求问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN \"level_1_cause\" = '设计问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN \"level_1_cause\" = '编码规范' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN \"level_1_cause\" = '打包问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN \"level_1_cause\" = '依赖问题' THEN 1 ELSE 0 END)\nFROM \"你的明细表名\"\n-- 注意：这里也要确认明细表里指向评审的字段名，根据 image_e33501 可能是所属评审\nWHERE \"所属评审_id\" = {{ $context.data.id }} \nGROUP BY \"module_id\";"}}}} userId=1 username=nocobase status=200 cost=7 app=main reqId=b2b5e9ec-7da6-445e-a879-8956a71cecbc bodySize=1464
