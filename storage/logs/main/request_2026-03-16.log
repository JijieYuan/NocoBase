(label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS level_1_count,\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label ? '已修复' OR (label ? '未复现' AND defect_status = '已关闭'))) AS level_1_fixed,\n    COUNT(id) FILTER (WHERE defect_rank = '二级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS level_2_count,\n    COUNT(id) FILTER (WHERE defect_rank = '二级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label ? '已修复' OR (label ? '未复现' AND defect_status = '已关闭'))) AS level_2_fixed,\n    COUNT(id) FILTER (WHERE defect_rank = '三级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS level_3_count,\n    COUNT(id) FILTER (WHERE defect_rank = '三级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label ? '已修复' OR (label ? '未复现' AND defect_status = '已关闭'))) AS level_3_fixed,\n\n    -- 3. 优先级统计 (P1/P2/P3)\n    COUNT(id) FILTER (WHERE priority = 'P1' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS p1_total,\n    COUNT(id) FILTER (WHERE priority = 'P1' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label ? '已修复' OR (label ? '未复现' AND defect_status = '已关闭'))) AS p1_fixed,\n    COUNT(id) FILTER (WHERE priority = 'P1' AND defect_status = '已关闭') AS p1_closed,\n    COUNT(id) FILTER (WHERE priority = 'P2' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS p2_total,\n    COUNT(id) FILTER (WHERE priority = 'P2' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label ? '已修复' OR (label ? '未复现' AND defect_status = '已关闭'))) AS p2_fixed,\n    COUNT(id) FILTER (WHERE priority = 'P3' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS p3_total,\n    COUNT(id) FILTER (WHERE priority = 'P3' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label ? '已修复' OR (label ? '未复现' AND defect_status = '已关闭'))) AS p3_fixed,\n\n    -- 4. 专项统计\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND (defect ILIKE '%退%' OR defect ILIKE '%回退%' OR defect ILIKE '%倒退%')) AS level_1_rollback,\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND defect ILIKE '%挂机%') AS level_1_hang,\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND (defect NOT ILIKE '%退%' AND defect NOT ILIKE '%回退%' AND defect NOT ILIKE '%倒退%' AND defect NOT ILIKE '%挂机%')) AS level_1_other,\n    COUNT(id) FILTER (WHERE label ? '复测未通过') AS retest_failed_count,\n    COUNT(id) FILTER (WHERE label ? '延期') AS total_delayed,\n    COUNT(id) FILTER (WHERE defect_status = '已修复') AS fixed_unupdated,\n    COUNT(id) FILTER (WHERE label ? '建议') AS suggested_count,\n\n    -- 5. 汇总与今日指标 (使用双引号 createdAt)\n    COUNT(id) FILTER (WHERE defect_status IN ('已关闭', '已阶段性关闭')) AS total_closed,\n    COUNT(id) FILTER (WHERE defect_status NOT IN ('已关闭', '已阶段性关闭', '无需修复')) AS open_count,\n    COUNT(id) FILTER (WHERE defect_status != '无需修复') AS module_total,\n    COUNT(id) FILTER (WHERE label ? '已修复') AS total_fixed,\n    COUNT(id) FILTER (WHERE \"createdAt\"::date = CURRENT_DATE) AS new_issue_total,\n    COUNT(id) FILTER (WHERE \"createdAt\"::date = CURRENT_DATE AND label ? '已修复') AS new_issue_fixed\n\nFROM defects\n-- 变量保持正确映射\nWHERE f_jmazop48q5l = {{$scopes.60k98hgp2i2.item.id}};"},"workflowId":351098810990592}],"revisions":[{"id":351091418529792,"createdAt":"2026-03-02T07:43:54.379Z","updatedAt":"2026-03-02T07:51:47.189Z","key":"bzoia89c3bz","title":"备份删除","enabled":false,"description":null,"type":"collection","triggerTitle":null,"config":{"mode":4,"collection":"defects"},"executed":0,"allExecuted":0,"current":null,"sync":false,"options":{"stackLimit":1,"deleteExecutionOnStatus":[]}},{"i