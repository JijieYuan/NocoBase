[32m2026-03-16 16:29:07 [info]  response /api/flow_nodes:update?filterByTk=353633807826945[39m method=POST path=/api/flow_nodes:update?filterByTk=353633807826945 res={"status":200} action={"actionName":"update","resourceName":"flow_nodes","params":{"filterByTk":"353633807826945","resourceName":"flow_nodes","actionName":"update","values":{"config":{"dataSource":"main","sql":"/* 1. 清理汇总表旧数据 */\nDELETE FROM \"defects_reason\" \nWHERE \"review_id\" = {{ $context.data.id }};\n\n/* 2. 重新统计并插入 */\nINSERT INTO \"defects_reason\" (\n    \"review_id\",\n    \"module_id\",\n    \"count_requirement\", \n    \"count_design\", \n    \"count_coding\", \n    \"count_package\", \n    \"count_dependency\"\n)\nSELECT \n    '{{ $context.data.id }}'::bigint,\n    t1.\"f_jmazop48q5l\",                -- 👈 根据 JSON，这才是模块的外键名\n    SUM(CASE WHEN t1.\"level_1_cause\" = '需求问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '设计问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '编码规范' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '打包问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '依赖问题' THEN 1 ELSE 0 END)\nFROM \"defects\" AS t1\nWHERE t1.\"f_0ipjqjhd3dt\" = {{ $context.data.id }} -- 👈 根据 JSON，这是评审外键\nGROUP BY t1.\"f_jmazop48q5l\";"}}}} userId=1 username=nocobase status=200 cost=7 app=main reqId=9edc4ec3-44b7-44ce-8d49-21ecb9cf7a23 bodySize=1317
