 f_jmazop48q5l = {{$context.data.f_jmazop48q5l}};"},"workflowId":351259402502144},{"id":351259402502187,"createdAt":"2026-03-03T05:58:55.579Z","updatedAt":"2026-03-03T05:58:55.609Z","key":"37co4fhv6af","title":"更新数据","upstreamId":351259402502156,"branchIndex":null,"downstreamId":null,"type":"update","config":{"usingAssignFormSchema":true,"assignFormSchema":{"_isJSONSchemaObject":true,"version":"2.0","name":"cvj5x8fwztw","type":"void","x-component":"Grid","x-initializer":"assignFieldValuesForm:configureFields","properties":{"52tf1uw7555":{"_isJSONSchemaObject":true,"version":"2.0","type":"void","x-component":"Grid.Row","properties":{"54q1g244x06":{"_isJSONSchemaObject":true,"version":"2.0","type":"void","x-component":"Grid.Col","properties":{"total_defect":{"_isJSONSchemaObject":true,"version":"2.0","type":"string","name":"total_defect","x-toolbar":"FormItemSchemaToolbar","x-settings":"fieldSettings:FormItem","x-component":"AssignedField","x-decorator":"FormItem","x-collection-field":"collection_quality.total_defect"}},"name":"54q1g244x06"}},"name":"52tf1uw7555"}}},"collection":"collection_quality","params":{"individualHooks":false,"filter":{"$and":[{"id":{"$eq":"{{$context.data.f_jmazop48q5l}}"}}]},"values":{"total_defect":"{{$jobsMapByNodeKey.itkejn83t4p}}"}}},"workflowId":351259402502144},{"id":351259402502180,"createdAt":"2026-03-03T05:58:55.574Z","updatedAt":"2026-03-03T05:58:59.529Z","key":"nf44eok9nnt","title":"查询数据","upstreamId":null,"branchIndex":null,"downstreamId":351259402502182,"type":"query","config":{"multiple":true,"collection":"module_summaries","params":{"filter":{"$and":[]},"sort":[],"page":1,"pageSize":20,"appends":[]}},"workflowId":351259402502144},{"id":351259402502183,"createdAt":"2026-03-03T05:58:55.576Z","updatedAt":"2026-03-03T05:59:08.289Z","key":"dsdg09lak9u","title":"全量","upstreamId":351259402502155,"branchIndex":0,"downstreamId":351259402502181,"type":"sql","config":{"dataSource":"main","sql":"SELECT\n    -- 1. 基础定位 ID\n    {{$scopes.60k98hgp2i2.item.id}} AS id,\n\n    -- 2. 模块缺陷占比 (分母同步增加轮次过滤，确保比例基于当前轮次总数)\n    (COUNT(d.id) FILTER (\n        WHERE (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL)\n        AND d.defect_status != '无需修复'\n    )::numeric \n    / NULLIF(\n        (SELECT COUNT(*) FROM defects \n         WHERE f_jmazop48q5l = {{$context.data.f_jmazop48q5l}} \n         AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)\n         AND defect_status != '无需修复'\n        ), 0)\n    ) AS module_defect_proportion,\n\n    -- 3. 模块总记录数\n    COUNT(d.id) AS module_total,\n\n    -- 4. 等级统计 (L1/L2/L3)\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level1' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL)) AS level_1_count,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level1' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL) AND (d.label ? '已修复' OR (d.label ? '未复现' AND d.defect_status = '已关闭'))) AS level_1_fixed,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level2' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL)) AS level_2_count,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level2' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL) AND (d.label ? '已修复' OR (d.label ? '未复现' AND d.defect_status = '已关闭'))) AS level_2_fixed,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level3' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL)) AS level_3_count,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level3' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL) AND (d.label ? '已修复' OR (d.label ? '未复现' AND d.defect_status = '已关闭'))) AS level_3_fixed,\n\n    -- 5. 优先级统计 (P1/P2/P3)\n    COUNT(d.id) FILTER (WHERE d.priority = 'P1' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL)) AS p1_total,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P1' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL) AND (d.label ? '已修复' OR (d.label ? '未复现' AND d.defect_status = '已关闭'))) AS p1_fixed,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P1' AND d.defect_status = '已关闭') AS p1_closed,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P2' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL)) AS p2_total,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P2' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL) AND (d.label ? '已修复' OR (d.label ? '未复现' AND d.defect_status = '已关闭'))) AS p2_fixed,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P3' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL)) AS p3_total,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P3' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL) AND (d.label ? '已修复' OR (d.label ? '未复现' AND d.defect_status = '已关闭'))) AS p3_fixed,\n\n    -- 6. 专项细分统计\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level1' AND (d.defect ILIKE '%退%' OR d.defect ILIKE '%回退%')) AS level_1_rollback,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level1' AND d.defect ILIKE '%挂机%') AS level_1_hang,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level1' AND d.defect NOT ILIKE '%退%' AND d.defect NOT ILIKE '%回退%' AND d.defect NOT ILIKE '%挂机%') AS level_1_other,\n    COUNT(d.id) FILTER (WHERE d.label ? '复测未通过') AS retest_failed_count,\n    COUNT(d.id) FILTER (WHERE d.label ? '延期') AS total_delayed,\n    COUNT(d.id) FILTER (WHERE d.label ? '建议') AS suggested_count,\n    COUNT(d.id) FILTER (WHERE d.defect_status = '已修复') AS fixed_unupdated,\n\n    -- 7. 汇总与今日指标\n    COUNT(d.id) FILTER (WHERE d.defect_status IN ('已关闭', '已阶段性关闭')) AS total_closed,\n    COUNT(d.id) FILTER (WHERE d.defect_status NOT IN ('已关闭', '已阶段性关闭', '无需修复')) AS open_count,\n    COUNT(d.id) FILTER (WHERE d.label ? '已修复') AS total_fixed,\n    COUNT(d.id) FILTER (WHERE d.\"createdAt\"::date = CURRENT_DATE) AS new_issue_total,\n    COUNT(d.id) FILTER (WHERE d.\"createdAt\"::date = CURRENT_DATE AND d.label ? '已修复') AS new_issue_fixed\n\nFROM defects d\nJOIN t_5yxbbcczpos m2m ON d.id = m2m.defect_id\nWHERE m2m.module_id = {{$scopes.60k98hgp2i2.item.id}};"},"workflowId":351259402502144}],"revisions":[{"id":351230602313728,"createdAt":"2026-03-03T02:10:02.383Z","updatedAt":"2026-03-03T02:42:34.634Z","key":"l3f3yraw2ao","title":"缺陷明细删除","enabled":false,"description":null,"type":"collection","triggerTitle":null,"config":{"mode":4,"collection":"defects"},"executed":0,"allExecuted":0,"current":null,"sync":false,"options":{"stackLimit":1,"deleteExecutionOnStatus":[]}},{"id":351234565931008,"createdAt":"2026-03-03T02:41:32.267Z","updatedAt":"2026-03-03T02:47:55.196Z","key":"l3f3yraw2ao","title":"缺陷明细删除","enabled":false,"description":null,"type":"collection","triggerTitle":null,"config":{"mode":4,"collection":"defects"},"executed":0,"allExecuted":0,"current":null,"sync":false,"options":{"stackLimit":1,"deleteExecutionOnStatus":[]}},{"id":351235237019648,"createdAt":"2026-03-03T02:46:52.978Z","updatedAt":"2026-03-03T02:54:03.014Z","key":"l3f3yraw2ao","title":"缺陷明细删除","enabled":false,"description":null,"type":"collection","triggerTitle":null,"config":{"mode":4,"collection":"defects"},"executed":0,"allExecuted":0,"current":null,"sync":false,"options":{"stackLimit":1,"deleteExecutionOnStatus":[]}},{"id":351236944101376,"createdAt":"2026-03-03T03:00:26.152Z","updatedAt":"2026-03-03T03:36:02.764Z","key":"l3f3yraw2ao","title":"缺陷明细删除","enabled":false,"description":null,"type":"collection","triggerTitle":null,"config":{"mode":4,"collection":"defects"},"executed":0,"allExecuted":0,"current":null,"sync":false,"options":{"stackLimit":1,"deleteExecutionOnStatus":[]}},{"id":351236835049472,"createdAt":"2026-03-03T02:59:34