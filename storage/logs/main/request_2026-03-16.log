[33m2026-03-16 10:37:38 [warn]  response /api/sqlCollection:execute         [39m method=POST path=/api/sqlCollection:execute res=[{"message":"Invalid SQL column or table reference"}] action={"actionName":"execute","resourceName":"sqlCollection","params":{"resourceName":"sqlCollection","actionName":"execute","values":{"sql":"WITH raw_stats AS (\n    -- 1. 统计原始合法数据 (根据你已有的 defects 表)\n    SELECT \n        f_0ipjqjhd3dt AS review_id,\n        level_1_cause,\n        COUNT(*) AS original_count\n    FROM defects\n    WHERE level_1_cause IS NOT NULL\n    GROUP BY f_0ipjqjhd3dt, level_1_cause\n),\nadjustments AS (\n    -- 2. 读取你的手动修正表 (假设你创建了 cause_adjustments 表)\n    -- 如果你还没创建修正表，可以先删掉这段 union 逻辑\n    SELECT review_id, cause_name, adj_value FROM cause_adjustments\n)\nSELECT \n    rs.review_id,\n    rs.level_1_cause,\n    -- 最终数量 = 自动统计 + 手动修正\n    (rs.original_count + COALESCE(ad.adj_value, 0)) AS final_count,\n    -- 最终占比计算\n    ROUND(\n        (rs.original_count + COALESCE(ad.adj_value, 0))::numeric / \n        NULLIF(SUM(rs.original_count + COALESCE(ad.adj_value, 0)) OVER(PARTITION BY rs.review_id), 0),\n    4) AS final_ratio\nFROM raw_stats rs\nLEFT JOIN adjustments ad ON rs.review_id = ad.review_id AND rs.level_1_cause = ad.cause_name"}}} userId=1 username=nocobase status=400 cost=25 app=main reqId=2be6c012-ca5a-40df-957f-152e734e0c10 bodySize=64
