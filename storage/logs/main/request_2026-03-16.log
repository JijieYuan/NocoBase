[32m2026-03-16 16:18:17 [info]  response /api/flow_nodes:update?filterByTk=353632453066753[39m method=POST path=/api/flow_nodes:update?filterByTk=353632453066753 res={"status":200} action={"actionName":"update","resourceName":"flow_nodes","params":{"filterByTk":"353632453066753","resourceName":"flow_nodes","actionName":"update","values":{"config":{"dataSource":"main","sql":"/* 1. 清理汇总表旧数据 */\nDELETE FROM \"defects_reason\" \nWHERE \"review_id\" = {{ $context.data.id }};\n\n/* 2. 重新统计并插入 */\nINSERT INTO \"defects_reason\" (\n    \"review_id\",\n    \"module_id\",\n    \"count_requirement\", \n    \"count_design\", \n    \"count_coding\", \n    \"count_package\", \n    \"count_dependency\"\n)\nSELECT \n    '{{ $context.data.id }}'::bigint, -- 对应 review_id\n    t1.\"module_id\",                   -- 👈 明确指明是来源表的 module_id\n    SUM(CASE WHEN t1.\"level_1_cause\" = '需求问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '设计问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '编码规范' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '打包问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '依赖问题' THEN 1 ELSE 0 END)\nFROM \"defects\" AS t1                  -- 👈 给明细表起个别名叫 t1\nWHERE t1.\"review_id\" = {{ $context.data.id }} \nGROUP BY t1.\"module_id\";"}}}} userId=1 username=nocobase status=200 cost=8 app=main reqId=bcabcb7a-9d1c-4464-82a7-8fe8db7c5b41 bodySize=1340
