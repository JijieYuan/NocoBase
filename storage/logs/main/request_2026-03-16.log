[32m2026-03-16 16:57:01 [info]  response /api/flow_nodes:update?filterByTk=353637326848001[39m method=POST path=/api/flow_nodes:update?filterByTk=353637326848001 res={"status":200} action={"actionName":"update","resourceName":"flow_nodes","params":{"filterByTk":"353637326848001","resourceName":"flow_nodes","actionName":"update","values":{"config":{"dataSource":"main","sql":"/* 1. 清理汇总表旧数据 */\n-- 同时尝试匹配两种可能的 ID 格式，确保清理干净\nDELETE FROM \"defects_reason\" \nWHERE \"review_id\" = {{ $context.data.id }} \n   OR \"review_id\" = 456; \n\n/* 2. 统计并重新插入 */\nINSERT INTO \"defects_reason\" (\n    \"review_id\",\n    \"module_id\",\n    \"count_requirement\", \n    \"count_design\", \n    \"count_coding\", \n    \"count_package\", \n    \"count_dependency\"\n)\nSELECT \n    t1.\"f_0ipjqjhd3dt\", -- 👈 直接从明细表里拿评审 ID (就是那个 456)\n    t1.\"f_jmazop48q5l\", \n    SUM(CASE WHEN t1.\"level_1_cause\" = '需求问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '设计问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '编码规范' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '打包问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '依赖问题' THEN 1 ELSE 0 END)\nFROM \"defects\" AS t1\n-- 👈 这里是关键！如果传进来的是长 ID 没效果，我们先手动写死 456 测试一次\nWHERE t1.\"f_0ipjqjhd3dt\" = 456 \nGROUP BY t1.\"f_jmazop48q5l\", t1.\"f_0ipjqjhd3dt\";"}}}} userId=1 username=nocobase status=200 cost=8 app=main reqId=4842e4f4-f22f-4631-8de9-f35b606f6747 bodySize=1469
