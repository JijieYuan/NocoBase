[33m2026-03-16 10:34:38 [warn]  response /api/sqlCollection:execute         [39m method=POST path=/api/sqlCollection:execute res=[{"message":"Only supports SELECT statements or WITH clauses"}] action={"actionName":"execute","resourceName":"sqlCollection","params":{"resourceName":"sqlCollection","actionName":"execute","values":{"sql":"CREATE VIEW view_defect_cause_summary AS\nWITH base_data AS (\n    -- 核心：识别哪些议题只关联了一个原因\n    -- 假设你的议题唯一标识是 gitlab_url 或 issue_id\n    SELECT \n        id, \n        f_0ipjqjhd3dt, -- 关联评审ID\n        level_1_cause, \n        COUNT(*) OVER(PARTITION BY gitlab_url) as label_count\n    FROM defects\n    WHERE level_1_cause IS NOT NULL\n)\nSELECT \n    f_0ipjqjhd3dt as review_id,\n    level_1_cause,\n    COUNT(*) as issue_count,\n    -- 占比计算：当前分类数 / 该评审下所有合法的议题数\n    ROUND(\n        COUNT(*)::numeric / NULLIF(SUM(COUNT(*)) OVER(PARTITION BY f_0ipjqjhd3dt), 0), \n    4) as ratio\nFROM base_data\nWHERE label_count = 1 -- 强制去重：只统计单选样本\nGROUP BY f_0ipjqjhd3dt, level_1_cause;"}}} userId=1 username=nocobase status=400 cost=11 app=main reqId=35c057db-bfe4-4e16-85da-5a4acdbe9285 bodySize=74
