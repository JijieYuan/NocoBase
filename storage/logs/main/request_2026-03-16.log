[32m2026-03-16 16:45:03 [info]  response /api/flow_nodes:update?filterByTk=353635793829889[39m method=POST path=/api/flow_nodes:update?filterByTk=353635793829889 res={"status":200} action={"actionName":"update","resourceName":"flow_nodes","params":{"filterByTk":"353635793829889","resourceName":"flow_nodes","actionName":"update","values":{"config":{"dataSource":"main","sql":"/* 1. 清理汇总表旧数据 */\nDELETE FROM \"defects_reason\" \nWHERE \"review_id\" = {{ $context.data.id }};\n\n/* 2. 统计明细并插入汇总表 */\nINSERT INTO \"defects_reason\" (\n    \"review_id\",\n    \"f_jmazop48q5l\",    -- 👈 汇总表里的物理外键名\n    \"count_requirement\", \n    \"count_design\", \n    \"count_coding\", \n    \"count_package\", \n    \"count_dependency\"\n)\nSELECT \n    '{{ $context.data.id }}'::bigint,\n    t1.\"f_jmazop48q5l\", -- 👈 明细表里的物理外键名\n    SUM(CASE WHEN t1.\"level_1_cause\" = '需求问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '设计问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '编码规范' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '打包问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '依赖问题' THEN 1 ELSE 0 END)\nFROM \"defects\" AS t1\nWHERE t1.\"f_0ipjqjhd3dt\" = {{ $context.data.id }} --\nGROUP BY t1.\"f_jmazop48q5l\";"}}}} userId=1 username=nocobase status=200 cost=6 app=main reqId=cd43d2a8-4b4e-410e-9e5f-a84a45a3122e bodySize=1308
