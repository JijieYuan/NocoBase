[33m2026-03-16 11:22:16 [warn]  response /api/sqlCollection:execute         [39m method=POST path=/api/sqlCollection:execute res=[{"message":"Invalid SQL column or table reference"}] action={"actionName":"execute","resourceName":"sqlCollection","params":{"resourceName":"sqlCollection","actionName":"execute","values":{"sql":"SELECT \n    -- 1. 获取评审记录的名称/轮次（假设评审表叫 review_records，请根据实际修改）\n    r.round AS review_round,\n    -- 2. 获取一级原因的真实文字名称（通过关联 ID 查找）\n    cause.name AS primary_cause,\n    -- 3. 统计数量\n    COUNT(d.id) AS issue_count,\n    -- 4. 计算占比\n    ROUND(\n        COUNT(d.id)::numeric / NULLIF(SUM(COUNT(d.id)) OVER(PARTITION BY d.f_0ipjqjhd3dt), 0), \n    4) AS ratio\nFROM defects d\n-- 关键：通过 ID 关联到原因表，拿到“代码错误”这几个字\nLEFT JOIN defect_reasons cause ON d.f_9ooxscwly52 = cause.id\nLEFT JOIN review_records r ON d.f_0ipjqjhd3dt = r.id\nWHERE d.f_9ooxscwly52 IS NOT NULL\nGROUP BY r.round, d.f_0ipjqjhd3dt, cause.name;"}}} userId=1 username=nocobase status=400 cost=41 app=main reqId=53505bb7-3670-40af-8e05-44d16d869375 bodySize=64
