[32m2026-03-16 16:44:57 [info]  response /api/workflows:update?filterByTk=353633807826944[39m method=POST path=/api/workflows:update?filterByTk=353633807826944 res={"status":200} action={"actionName":"update","resourceName":"workflows","params":{"filterByTk":"353633807826944","resourceName":"workflows","actionName":"update","values":{"id":353633807826944,"createdAt":"2026-03-16T08:28:59.582Z","updatedAt":"2026-03-16T08:43:16.414Z","key":"8way4v31o8w","title":"缺陷原因汇总增加更新","enabled":false,"description":null,"type":"collection","triggerTitle":"缺陷原因汇总增加更新","executed":0,"allExecuted":0,"current":true,"sync":false,"options":{"stackLimit":1,"deleteExecutionOnStatus":[]},"nodes":[{"id":353633807826945,"createdAt":"2026-03-16T08:28:59.586Z","updatedAt":"2026-03-16T08:29:07.116Z","key":"if7j7gptm8l","title":"SQL 操作","upstreamId":null,"branchIndex":null,"downstreamId":null,"type":"sql","config":{"dataSource":"main","sql":"/* 1. 清理汇总表旧数据 */\nDELETE FROM \"defects_reason\" \nWHERE \"review_id\" = {{ $context.data.id }};\n\n/* 2. 重新统计并插入 */\nINSERT INTO \"defects_reason\" (\n    \"review_id\",\n    \"module_id\",\n    \"count_requirement\", \n    \"count_design\", \n    \"count_coding\", \n    \"count_package\", \n    \"count_dependency\"\n)\nSELECT \n    '{{ $context.data.id }}'::bigint,\n    t1.\"f_jmazop48q5l\",                -- 👈 根据 JSON，这才是模块的外键名\n    SUM(CASE WHEN t1.\"level_1_cause\" = '需求问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '设计问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '编码规范' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '打包问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '依赖问题' THEN 1 ELSE 0 END)\nFROM \"defects\" AS t1\nWHERE t1.\"f_0ipjqjhd3dt\" = {{ $context.data.id }} -- 👈 根据 JSON，这是评审外键\nGROUP BY t1.\"f_jmazop48q5l\";"},"workflowId":353633807826944}],"revisions":[{"id":353630410440704,"createdAt":"2026-03-16T08:01:59.183Z","updatedAt":"2026-03-16T08:01:59.183Z","key":"8way4v31o8w