','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL)\n        AND d.defect_status != '无需修复'\n    )::numeric \n    / NULLIF(\n        (SELECT COUNT(*) FROM defects \n         WHERE f_jmazop48q5l = {{$context.data.f_jmazop48q5l}} \n         AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)\n         AND defect_status != '无需修复'\n        ), 0)\n    ) AS module_defect_proportion,\n\n    -- 3. 模块总记录数\n    COUNT(d.id) AS module_total,\n\n    -- 4. 等级统计 (L1/L2/L3)\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level1' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL)) AS level_1_count,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level1' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL) AND (d.label ? '已修复' OR (d.label ? '未复现' AND d.defect_status = '已关闭'))) AS level_1_fixed,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level2' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL)) AS level_2_count,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level2' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL) AND (d.label ? '已修复' OR (d.label ? '未复现' AND d.defect_status = '已关闭'))) AS level_2_fixed,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level3' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL)) AS level_3_count,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level3' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL) AND (d.label ? '已修复' OR (d.label ? '未复现' AND d.defect_status = '已关闭'))) AS level_3_fixed,\n\n    -- 5. 优先级统计 (P1/P2/P3)\n    COUNT(d.id) FILTER (WHERE d.priority = 'P1' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL)) AS p1_total,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P1' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL) AND (d.label ? '已修复' OR (d.label ? '未复现' AND d.defect_status = '已关闭'))) AS p1_fixed,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P1' AND d.defect_status = '已关闭') AS p1_closed,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P2' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL)) AS p2_total,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P2' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL) AND (d.label ? '已修复' OR (d.label ? '未复现' AND d.defect_status = '已关闭'))) AS p2_fixed,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P3' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL)) AS p3_total,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P3' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL) AND (d.label ? '已修复' OR (d.label ? '未复现' AND d.defect_status = '已关闭'))) AS p3_fixed,\n\n    -- 6. 专项细分统计\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level1' AND (d.defect ILIKE '%退%' OR d.defect ILIKE '%回退%')) AS level_1_rollback,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level1' AND d.defect ILIKE '%挂机%') AS level_1_hang,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level1' AND d.defect NOT ILIKE '%退%' AND d.defect NOT ILIKE '%回退%' AND d.defect NOT ILIKE '%挂机%') AS level_1_other,\n    COUNT(d.id) FILTER (WHERE d.label ? '复测未通过') AS retest_failed_count,\n    COUNT(d.id) FILTER (WHERE d.label ? '延期') AS total_delayed,\n    COUNT(d.id) FILTER (WHERE d.label ? '建议') AS suggested_count,\n    COUNT(d.id) FILTER (WHERE d.defect_status = '已修复') AS fixed_unupdated,\n\n    -- 7. 汇总与今日指标\n    COUNT(d.id) FILTER (WHERE d.defect_status IN ('已关闭', '已阶段性关闭')) AS total_closed,\n    COUNT(d.id) FILTER (WHERE d.defect_status NOT IN ('已关闭', '已阶段性关闭', '无需修复')) AS open_count,\n    COUNT(d.id) FILTER (WHERE d.label ? '已修复') AS total_fixed,\n    COUNT(d.id) FILTER (WHERE d.\"createdAt\"::date = CURRENT_DATE) AS new_issue_total,\n    COUNT(d.id) FILTER (WHERE d.\"createdAt\"::date = CURRENT_DATE AND d.label ? '已修复') AS new_issue_fixed\n\nFROM defects d\nJOIN t_5yxbbcczpos m2m ON d.id = m2m.defect_id\nWHERE m2m.module_id = {{$scopes.60k98hgp2i2.item.id}};"},"workflowId":351260218294272},{"id":351260218294312,"createdAt":"2026-03-03T06:05:24.299Z","updatedAt":"2026-03-03T06:07:53.709Z","key":"4oowzbkwxg4","title":"全项目总计","upstreamId":351260218294314,"branchIndex":null,"downstreamId":351260530769920,"type":"sql","config":{"dataSource":"main","sql":"SELECT \n    COUNT(id) AS project_total_count \nFROM defects \nWHERE (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)\nAND defect_status != '无需修复'\nAND f_jmazop48q5l = {{$context.data.f_jmazop48q5l}};"},"workflowId":351260218294272},{"id":351260530769920,"createdAt":"2026-03-03T06:07:53.694Z","updatedAt":"2026-03-03T06:07:53.724Z","key":"h7o8c0lt9sn","title":"并行分支","upstreamId":351260218294312,"branchIndex":null,"downstreamId":null,"type":"parallel","config":{},"workflowId":351260218294272},{"id":351260551741440,"createdAt":"2026-03-03T06:08:03.203Z","updatedAt":"2026-03-03T06:08:59.577Z","key":"hllf1jj2xg8","title":"SQL 操作","upstreamId":351260530769920,"branchIndex":1,"downstreamId":351260558032896,"type":"sql","config":{"dataSource":"main","sql":"SELECT \n    COUNT(id) AS module_total \nFROM defects \nWHERE f_jmazop48q5l = {{$context.data.f_jmazop48q5l}};"},"workflowId":351260218294272},{"id":351260558032896,"createdAt":"2026-03-03T06:08:06.343Z","updatedAt":"2026-03-03T06:09:50.017Z","key":"4ocwze6yczu","title":"计算","upstreamId":351260551741440,"branchIndex":null,"downstreamId":351260574810112,"type":"calculation","config":{"engine":"formula.js","expression":"{{$jobsMapByNodeKey.hllf1jj2xg8}}[0].module_total"},"workflowId":351260218294272},{"id":351260574810112,"createdAt":"2026-03-03T06:08:14.909Z","updatedAt":"2026-03-03T06:10:49.223Z","key":"esqynjgri0f","title":