[32m2026-03-16 16:20:38 [info]  response /api/flow_nodes:update?filterByTk=353632639713281[39m method=POST path=/api/flow_nodes:update?filterByTk=353632639713281 res={"status":200} action={"actionName":"update","resourceName":"flow_nodes","params":{"filterByTk":"353632639713281","resourceName":"flow_nodes","actionName":"update","values":{"config":{"dataSource":"main","sql":"/* 1. 清理汇总表旧数据 */\nDELETE FROM \"defects_reason\" \nWHERE \"review_id\" = {{ $context.data.id }};\n\n/* 2. 重新统计并插入 */\nINSERT INTO \"defects_reason\" (\n    \"review_id\",\n    \"module_id\",         -- 汇总表里的外键名（如果报错再改它）\n    \"count_requirement\", \n    \"count_design\", \n    \"count_coding\", \n    \"count_package\", \n    \"count_dependency\"\n)\nSELECT \n    '{{ $context.data.id }}'::bigint,\n    t1.\"module\",         -- 👈 根据报错暗示，明细表里叫 module\n    SUM(CASE WHEN t1.\"level_1_cause\" = '需求问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '设计问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '编码规范' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '打包问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '依赖问题' THEN 1 ELSE 0 END)\nFROM \"defects\" AS t1\nWHERE t1.\"review_id\" = {{ $context.data.id }} \nGROUP BY t1.\"module\";    -- 👈 也要同步改这里"}}}} userId=1 username=nocobase status=200 cost=13 app=main reqId=95ee45a2-de11-42bd-b506-9ca41b1bc888 bodySize=1350
