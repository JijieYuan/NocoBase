[32m2026-03-16 10:24:09 [info]  response /api/workflows:update?filterByTk=351103447793664[39m method=POST path=/api/workflows:update?filterByTk=351103447793664 res={"status":200} action={"actionName":"update","resourceName":"workflows","params":{"filterByTk":"351103447793664","resourceName":"workflows","actionName":"update","values":{"id":351103447793664,"createdAt":"2026-03-02T09:19:30.653Z","updatedAt":"2026-03-03T02:10:43.718Z","key":"vguhdmq97q9","title":"备份增加更新（旧）","enabled":false,"description":null,"type":"collection","triggerTitle":null,"executed":0,"allExecuted":0,"current":true,"sync":false,"options":{"stackLimit":1,"deleteExecutionOnStatus":[]},"nodes":[{"id":351103447793668,"createdAt":"2026-03-02T09:19:30.666Z","updatedAt":"2026-03-02T09:19:30.674Z","key":"kv7u9kwa6q9","title":"一总","upstreamId":351103447793665,"branchIndex":null,"downstreamId":351103447793669,"type":"calculation","config":{"engine":"formula.js","expression":"{{$jobsMapByNodeKey.dsdg09lak9u}}[0].level_1_count"},"workflowId":351103447793664},{"id":351103447793669,"createdAt":"2026-03-02T09:19:30.666Z","updatedAt":"2026-03-02T09:19:30.675Z","key":"q441f2kq623","title":"一修","upstreamId":351103447793668,"branchIndex":null,"downstreamId":351103447793670,"type":"calculation","config":{"engine":"formula.js","expression":"{{$jobsMapByNodeKey.dsdg09lak9u}}[0].level_1_fixed"},"workflowId":351103447793664},{"id":351103447793675,"createdAt":"2026-03-02T09:19:30.670Z","updatedAt":"2026-03-02T09:19:30.678Z","key":"h190hihj2sd","title":"并行分支","upstreamId":351103447793672,"branchIndex":null,"downstreamId":null,"type":"parallel","config":{},"workflowId":351103447793664},{"id":351103447793676,"createdAt":"2026-03-02T09:19:30.671Z","updatedAt":"2026-03-02T09:19:30.679Z","key":"5mqxo96hkzs","title":"总数","upstreamId":351103447793675,"branchIndex":1,"downstreamId":351103447793666,"type":"sql","config":{"dataSource":"main","sql":"SELECT \n    COUNT(id) AS module_total \nFROM defects \nWHERE f_jmazop48q5l = {{$context.data.f_jmazop48q5l}};"},"workflowId":351103447793664},{"id":351103447793665,"createdAt":"2026-03-02T09:19:30.658Z","updatedAt":"2026-03-02T09:19:39.949Z","key":"dsdg09lak9u","title":"全量","upstreamId":351103447793671,"branchIndex":0,"downstreamId":351103447793668,"type":"sql","config":{"dataSource":"main","sql":"SELECT\n    -- 1. 基础定位 ID (确保返回一行数据)\n    {{$scopes.60k98hgp2i2.item.id}} AS id,\n\n    -- 2. 模块缺陷总数 (全量统计，通过中间表关联)\n    COUNT(d.id) AS module_total,\n\n    -- 3. 缺陷等级统计 (修正关键词：'一级' -> 'level1', '二级' -> 'level2', '三级' -> 'level3')\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level1' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL)) AS level_1_count,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level1' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL) AND (d.label ? '已修复' OR (d.label ? '未复现' AND d.defect_status = '已关闭'))) AS level_1_fixed,\n    \n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level2' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL)) AS level_2_count,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level2' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL) AND (d.label ? '已修复' OR (d.label ? '未复现' AND d.defect_status = '已关闭'))) AS level_2_fixed,\n    \n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level3' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL)) AS level_3_count,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level3' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL) AND (d.label ? '已修复' OR (d.label ? '未复现' AND d.defect_status = '已关闭'))) AS level_3_fixed,\n\n    -- 4. 优先级统计 (P1/P2/P3)\n    COUNT(d.id) FILTER (WHERE d.priority = 'P1' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL)) AS p1_total,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P1' AND d.defect_status = '已关闭') AS p1_closed,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P2' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL)) AS p2_total,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P3' AND (NOT (d.label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR d.label IS NULL)) AS p3_total,\n\n    -- 5. 汇总与专项统计\n    COUNT(d.id) FILTER (WHERE d.defect_status IN ('已关闭', '已阶段性关闭')) AS total_closed,\n    COUNT(d.id) FILTER (WHERE d.defect_status NOT IN ('已关闭', '已阶段性关闭', '无需修复')) AS open_count,\n    COUNT(d.id) FILTER (WHERE d.label ? '已修复') AS total_fixed,\n    COUNT(d.id) FILTER (WHERE d.\"createdAt\"::date = CURRENT_DATE) AS new_issue_total,\n    COUNT(d.id) FILTER (WHERE d.\"createdAt\"::date = CURRENT_DATE AND d.label ? '已修复') AS new_issue_fixed\n\nFROM defects d\n-- 【关键修正】加入中间表关联，否则无法按“工程图/草图”模块统计\nJOIN t_5yxbbcczpos m2m ON d.id = m2m.defect_id\n-- 过滤出当前循环到的具体业务模块 ID\nWHERE m2m.module_id = {{$scopes.60k98hgp2i2.item.id}};"},"workflowId":351103447793664},{"id":351103447793666,"createdAt":"2026-03-02T09:19:30.664Z","updatedAt":"2026-03-02T09:19:30.673Z","key":"421nbbkd8io","title":"计算","upstreamId":351103447793676,"branchIndex":null,"downstreamId":351103447793667,"type":"calculation","config":{"engine":"formula.js","expression":"{{$jobsMapByNodeKey.5mqxo96hkzs}}[0].module_total"},"workflowId":351103447793664},{"id":351103447793667,"createdAt":"2026-03-02T09:19:30.665Z","updatedAt":"2026-03-02T09:19:30.674Z","key":"9teprp6eeb7","title":"更新数据","upstreamId":351103447793666,"branchIndex":null,"downstreamId":null,"type":"update","config":{"usingAssignFormSchema":true,"assignFormSchema":{"_isJSONSchemaObject":true,"version":"2.0","name":"yn6qq6norxm","type":"void","x-component":"Grid","x-initializer":"assignFieldValuesForm:configureFields","properties":{"s7zd8wl23kj":{"_isJSONSchemaObject":true,"version":"2.0","type":"void","x-component":"Grid.Row","properties":{"hx5fzm9mftg":{"_isJSONSchemaObject":true,"version":"2.0","type":"void","x-component":"Grid.Col","properties":{"total_defect":{"_isJSONSchemaObject":true,"version":"2.0","type":"string","name":"total_defect","x-toolbar":"FormItemSchemaToolbar","x-settings":"fieldSettings:FormItem","x-component":"AssignedField","x-decorator":"FormItem","x-collection-field":"collection_quality.total_defect"}},"name":"hx5fzm9mftg"}},"name":"s7zd8wl23kj"}}},"collection":"collection_quality","params":{"individualHooks":false,"filter":{"$and":[{"id":{"$eq":"{{$context.data.f_jmazop48q5l}}"}}]},"values":{"total_defect":"{{$jobsMapByNodeKey.421nbbkd8io}}"}}},"workflowId":351103447793664},{"id":351103447793670,"createdAt":"2026-03-02T09:19:30.667Z","updatedAt":"2026-03-02T09:19:30.675Z","key":"dr6kq9yrfa7","title":"总数","upstreamId":351103447793669,"branchIndex":null,"downstreamId":351103447793674,"type":"calculation","config":{"engine":"formula.js","expression":"{{$jobsMapByNodeKey.dsdg09lak9u}}[0].module_total"},"workflowId":351103447793664},{"id":351103447793671,"createdAt":"2026-03-02T09:19:30.667Z","updatedAt":"2026-03-02T09:19:30.676Z","key":"60k98hgp2i2","title":"循环","upstreamId":351103447793675,"branchIndex":0,"downstreamId":null,"type":"loop","config":{"target":"{{$jobsMapByNodeKey.nf44eok9nnt}}","condition":false,"exit":0},"workflowId":351103447793664},{"id":351103447793672,"createdAt":"2026-03-02T09:19:30.668Z","updatedAt":"2026-03-02T09:19:30.676Z","key":"nf44eok9nnt","title":"查询数据","upstreamId":null,"branchIndex":null,"downstreamId":351103447793675,"type":"query","config":{"multiple":true,"collection":"module_summaries","params":{"filter":{"$and":[]},"sort":[],"page":1,"pageSize":20,"appends":[]}},"workflowId":351103447793664},{"id":351103447793673,"createdAt":"2026-03-02T09:19:30.669Z","updatedAt":"2026-03-02T09:19:30.677Z","key":"een2u5iw2xl","title":"更新数据","upstreamId":351103447793674,"branchIndex":null,"downstreamId":null,"type":"update","config":{"usingAssignFormSchema":true,"assignFormSchema":{"_isJSO