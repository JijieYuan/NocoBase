[32m2026-03-16 16:59:46 [info]  response /api/flow_nodes:update?filterByTk=353637668683777[39m method=POST path=/api/flow_nodes:update?filterByTk=353637668683777 res={"status":200} action={"actionName":"update","resourceName":"flow_nodes","params":{"filterByTk":"353637668683777","resourceName":"flow_nodes","actionName":"update","values":{"config":{"dataSource":"main","sql":"/* 1. 清理汇总表旧数据 */\nDELETE FROM \"defects_reason\" \nWHERE \"review_id\" = 456; \n\n/* 2. 统计并重新插入（补充系统必填字段） */\nINSERT INTO \"defects_reason\" (\n    \"id\",                -- 👈 手动指定 ID\n    \"createdAt\",         -- 👈 创建时间\n    \"updatedAt\",         -- 👈 更新时间\n    \"review_id\",\n    \"module_id\",\n    \"count_requirement\", \n    \"count_design\", \n    \"count_coding\", \n    \"count_package\", \n    \"count_dependency\"\n)\nSELECT \n    -- 使用时间戳 + 随机数生成一个伪雪花 ID，防止冲突\n    (extract(epoch from now()) * 1000 + floor(random() * 1000))::bigint,\n    NOW(),               -- 当前时间\n    NOW(),               -- 当前时间\n    t1.\"f_0ipjqjhd3dt\", \n    t1.\"f_jmazop48q5l\", \n    SUM(CASE WHEN t1.\"level_1_cause\" = '需求问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '设计问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '编码规范' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '打包问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '依赖问题' THEN 1 ELSE 0 END)\nFROM \"defects\" AS t1\nWHERE t1.\"f_0ipjqjhd3dt\" = 456 \nGROUP BY t1.\"f_jmazop48q5l\", t1.\"f_0ipjqjhd3dt\";"}}}} userId=1 username=nocobase status=200 cost=7 app=main reqId=0b998563-f0b4-434c-9fba-71b6713f82eb bodySize=1600
