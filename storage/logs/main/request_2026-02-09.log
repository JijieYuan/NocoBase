[32m2026-02-09 13:36:21 [info]  response /api/flowModels:save               [39m method=POST path=/api/flowModels:save res={"status":200} action={"actionName":"save","resourceName":"flowModels","params":{"resourceName":"flowModels","actionName":"save","values":{"uid":"944dc41dcd4","use":"ChartBlockModel","parentId":"fcc22a6525c","subKey":"items","subType":"array","stepParams":{"chartSettings":{"configure":{"query":{"collectionPath":["main","collection_quality"],"measures":[{"field":["fix_rate"],"aggregation":"avg"},{"field":["fixed_count"],"aggregation":"sum"},{"field":["defect_count"],"aggregation":"sum"}],"dimensions":[],"orders":[],"mode":"builder"},"chart":{"option":{"mode":"custom","builder":{"legend":true,"tooltip":true,"label":false,"type":"area","xField":"fix_rate","smooth":false,"xAxisLabelRotate":0,"yAxisSplitLine":true,"stack":false},"raw":"const list = ctx.data.objects || [];\n// 1. 安全抓取汇总后的第一行数据\nconst data = list[0] || {};\n\n// 2. 提取已修复数和缺陷总数（变量名需与数据库标识一致）\nconst fixed = parseFloat(data.fixed_count) || 0; \nconst defect = parseFloat(data.defect_count) || 0;\n\n// 3. 计算全局修复率\nconst rate = defect > 0 ? (fixed / defect) : 0;\nconst remaining = 1 - rate;\n\nreturn {\n  title: {\n    text: (rate * 100).toFixed(0) + '%',\n    left: 'center', top: 'center',\n    textStyle: { fontSize: 26, color: '#333', fontWeight: 'bold' }\n  },\n  tooltip: { \n    trigger: 'item',\n    // 采用安全的字符串模板，避免 React 报错\n    formatter: '修复进度详情 <br/>{b}: {d}%' \n  },\n  series: [{\n    type: 'pie',\n    radius: ['65%', '85%'],\n    silent: false,\n    label: { show: false },\n    data: [\n      { \n        value: rate, \n        name: '已修复 (' + fixed + '个)', \n        itemStyle: { color: '#4e73df' } // 修复进度建议用绿色\n      },\n      { \n        value: remaining > 0 ? remaining : 0, \n        name: '待修复 (' + (defect - fixed) + '个)', \n        itemStyle: { color: '#f2f2f2' } \n      }\n    ]\n  }]\n};\n"}}}}},"sortIndex":1,"flowRegistry":{}}}} userId=1 username=nocobase status=200 cost=