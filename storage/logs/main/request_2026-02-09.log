[32m2026-02-09 10:50:37 [info]  response /api/flowModels:save               [39m method=POST path=/api/flowModels:save res={"status":200} action={"actionName":"save","resourceName":"flowModels","params":{"resourceName":"flowModels","actionName":"save","values":{"uid":"ab949ea3c42","use":"ChartBlockModel","parentId":"b5edaff7aa1","subKey":"items","subType":"array","stepParams":{"chartSettings":{"configure":{"query":{"collectionPath":["main","collection_quality"],"measures":[{"field":["testing_rate"],"aggregation":"avg"}],"dimensions":[],"orders":[],"mode":"builder"},"chart":{"option":{"mode":"custom","builder":{"legend":true,"tooltip":true,"label":false,"type":"pie","xAxisLabelRotate":0,"yAxisSplitLine":true,"pieCategory":"testing_rate","pieRadiusInner":0,"pieRadiusOuter":70,"pieLabelType":"percent","pieValue":"testing_rate"},"raw":"// 1. 从上下文 ctx 中获取数据库实时数据\nconst list = ctx.data.objects || [];\n\n// 2. 计算“测试率”的平均值\n// 假设你的字段名是 testing_rate\nconst totalRate = list.reduce((sum, item) => sum + (parseFloat(item.testing_rate) || 0), 0);\nconst avgRate = list.length > 0 ? (totalRate / list.length) : 0;\n\n// 3. 计算“补位”数值，让圆环不封口\nconst remaining = 1 - avgRate;\n\nreturn {\n  title: {\n    // 动态显示百分比文字\n    text: (avgRate * 100).toFixed(0) + '%',\n    left: 'center',\n    top: 'center',\n    textStyle: { fontSize: 22, color: '#333', fontWeight: 'bold' }\n  },\n  tooltip: { trigger: 'item' },\n  series: [\n    {\n      type: 'pie',\n      radius: ['65%', '85%'], // 设置内外径比例，形成圆环\n      silent: true,           // 禁用点击交互，保持UI纯净\n      label: { show: false },\n      data: [\n        { \n          value: avgRate, \n          name: '已测试', \n          itemStyle: { color: '#4e73df' } // 进度部分颜色\n        },\n        { \n          value: remaining > 0 ? remaining : 0, \n          name: '未完成', \n          itemStyle: { color: '#f0f0f0' } // 剩余部分显示为灰色背景\n        }\n      ]\n    }\n  ]\n};"}},"layout":{"configuration":{"chart":{"option":{}},"query":{}}}}}},"sortIndex":7,"flowRegistry":{}}}} userId=1 username=nocobase status=200 cost=26 app=main reqId=a1cba30b-84a2-4bf3-bb28-991d4d0fcf9a bodySize=22
