[32m2026-02-09 10:58:48 [info]  response /api/flowModels:save               [39m method=POST path=/api/flowModels:save res={"status":200} action={"actionName":"save","resourceName":"flowModels","params":{"resourceName":"flowModels","actionName":"save","values":{"uid":"ab949ea3c42","use":"ChartBlockModel","parentId":"b5edaff7aa1","subKey":"items","subType":"array","stepParams":{"chartSettings":{"configure":{"query":{"collectionPath":["main","collection_quality"],"measures":[{"field":["testing_rate"],"aggregation":"avg"}],"dimensions":[],"orders":[],"mode":"builder"},"chart":{"option":{"mode":"custom","builder":{"legend":true,"tooltip":true,"label":false,"type":"pie","xAxisLabelRotate":0,"yAxisSplitLine":true,"pieCategory":"testing_rate","pieRadiusInner":0,"pieRadiusOuter":70,"pieLabelType":"percent","pieValue":"testing_rate"},"raw":"// 1. 获取实时数据\nconst list = ctx.data.objects || [];\nconst totalRate = list.reduce((sum, item) => sum + (parseFloat(item.testing_rate) || 0), 0);\nconst avgRate = list.length > 0 ? (totalRate / list.length) : 0;\nconst remaining = 1 - avgRate;\n\nreturn {\n  // 只保留中心的百分比数字，删除多余标题\n  title: {\n    text: (avgRate * 100).toFixed(0) + '%',\n    left: 'center',\n    top: 'center',\n    textStyle: { fontSize: 28, color: '#333', fontWeight: 'bold' }\n  },\n\n  // 启用悬浮提示，在这里标注“测试率”\n  tooltip: { \n    trigger: 'item',\n    backgroundColor: 'rgba(255, 255, 255, 0.9)',\n    formatter: '<b>测试率分析</b><br/>{b}: {d}%' // 悬浮时清晰显示\n  },\n\n  series: [\n    {\n      name: '测试率',         // 系列名称，用于提示框标题\n      type: 'pie',\n      radius: ['65%', '85%'], \n      silent: false,           // 必须设为 false 才能触发悬浮提示\n      label: { show: false },\n      emphasis: {\n        scale: true,           // 悬浮时圆环略微放大，增加反馈感\n        itemStyle: {\n          shadowBlur: 10,\n          shadowColor: 'rgba(0, 0, 0, 0.2)'\n        }\n      },\n      data: [\n        { \n          value: avgRate, \n          name: '已测试进度', \n          itemStyle: { color: '#4e73df' } \n        },\n        { \n          value: remaining > 0 ? remaining : 0, \n          name: '剩余待测', \n          itemStyle: { color: '#f2f2f2' } \n        }\n      ]\n    }\n  ]\n};\n"},"events":{"mode":"custom","raw":"// chart.off('click');\n// chart.on('click', 'series', function() {\n//   ctx.openView(ctx.model.uid + '-1', {\n//     mode: 'dialog',\n//     size: 'large',\n//     defineProperties: {}, // inject context into the new view\n//   });\n// });\n"}},"layout":{"configuration":{"chart":{"option":{}},"query":{}}}}}},"sortIndex":7,"flowRegistry":{}}}} userId=1 username=nocobase status=200 cost=11 app=main reqId=902764dd-e9e2-4245-8c6f-1cbec326145d bodySize=22
