[34m2026-03-18 11:47:14 [debug] config of node                              [39m data={"dataSource":"main","sql":"SELECT\n    -- 1. еҹәзЎҖе®ҡдҪҚ ID\n    {{$scopes.60k98hgp2i2.item.id}} AS id,\n\n    -- 2. жЁЎеқ—зјәйҷ·еҚ жҜ” (еҲҶжҜҚеҗҢжӯҘеўһеҠ иҪ®ж¬ЎиҝҮж»ӨпјҢзЎ®дҝқжҜ”дҫӢеҹәдәҺеҪ“еүҚиҪ®ж¬ЎжҖ»ж•°)\n    (COUNT(d.id) FILTER (\n        WHERE (NOT (d.label ?| ARRAY['еҠҹиғҪеұҸи”Ҫ','е·ІжӢ’з»қ','е»әи®®','з”іиҜ·еҗҰеҶі','ж•°жҚ®ејӮеёё','и®ҫи®ЎеҰӮжӯӨ','йңҖжұӮ']) OR d.label IS NULL)\n        AND d.defect_status != 'ж— йңҖдҝ®еӨҚ'\n    )::numeric \n    / NULLIF(\n        (SELECT COUNT(*) FROM defects \n         WHERE f_jmazop48q5l = {{$context.data.f_jmazop48q5l}} \n         AND (NOT (label ?| ARRAY['еҠҹиғҪеұҸи”Ҫ','е·ІжӢ’з»қ','е»әи®®','з”іиҜ·еҗҰеҶі','ж•°жҚ®ејӮеёё','и®ҫи®ЎеҰӮжӯӨ','йңҖжұӮ']) OR label IS NULL)\n         AND defect_status != 'ж— йңҖдҝ®еӨҚ'\n        ), 0)\n    ) AS module_defect_proportion,\n\n    -- 3. жЁЎеқ—жҖ»и®°еҪ•ж•°\n    COUNT(d.id) AS module_total,\n\n    -- 4. зӯүзә§з»ҹи®Ў (L1/L2/L3)\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level1' AND (NOT (d.label ?| ARRAY['еҠҹиғҪеұҸи”Ҫ','е·ІжӢ’з»қ','е»әи®®','з”іиҜ·еҗҰеҶі','ж•°жҚ®ејӮеёё','и®ҫи®ЎеҰӮжӯӨ','йңҖжұӮ']) OR d.label IS NULL)) AS level_1_count,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level1' AND (NOT (d.label ?| ARRAY['еҠҹиғҪеұҸи”Ҫ','е·ІжӢ’з»қ','е»әи®®','з”іиҜ·еҗҰеҶі','ж•°жҚ®ејӮеёё','и®ҫи®ЎеҰӮжӯӨ','йңҖжұӮ']) OR d.label IS NULL) AND (d.label ? 'е·Ідҝ®еӨҚ' OR (d.label ? 'жңӘеӨҚзҺ°' AND d.defect_status = 'е·Іе…ій—ӯ'))) AS level_1_fixed,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level2' AND (NOT (d.label ?| ARRAY['еҠҹиғҪеұҸи”Ҫ','е·ІжӢ’з»қ','е»әи®®','з”іиҜ·еҗҰеҶі','ж•°жҚ®ејӮеёё','и®ҫи®ЎеҰӮжӯӨ','йңҖжұӮ']) OR d.label IS NULL)) AS level_2_count,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level2' AND (NOT (d.label ?| ARRAY['еҠҹиғҪеұҸи”Ҫ','е·ІжӢ’з»қ','е»әи®®','з”іиҜ·еҗҰеҶі','ж•°жҚ®ејӮеёё','и®ҫи®ЎеҰӮжӯӨ','йңҖжұӮ']) OR d.label IS NULL) AND (d.label ? 'е·Ідҝ®еӨҚ' OR (d.label ? 'жңӘеӨҚзҺ°' AND d.defect_status = 'е·Іе…ій—ӯ'))) AS level_2_fixed,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level3' AND (NOT (d.label ?| ARRAY['еҠҹиғҪеұҸи”Ҫ','е·ІжӢ’з»қ','е»әи®®','з”іиҜ·еҗҰеҶі','ж•°жҚ®ејӮеёё','и®ҫи®ЎеҰӮжӯӨ','йңҖжұӮ']) OR d.label IS NULL)) AS level_3_count,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level3' AND (NOT (d.label ?| ARRAY['еҠҹиғҪеұҸи”Ҫ','е·ІжӢ’з»қ','е»әи®®','з”іиҜ·еҗҰеҶі','ж•°жҚ®ејӮеёё','и®ҫи®ЎеҰӮжӯӨ','йңҖжұӮ']) OR d.label IS NULL) AND (d.label ? 'е·Ідҝ®еӨҚ' OR (d.label ? 'жңӘеӨҚзҺ°' AND d.defect_status = 'е·Іе…ій—ӯ'))) AS level_3_fixed,\n\n    -- 5. дјҳе…Ҳзә§з»ҹи®Ў (P1/P2/P3)\n    COUNT(d.id) FILTER (WHERE d.priority = 'P1' AND (NOT (d.label ?| ARRAY['еҠҹиғҪеұҸи”Ҫ','е·ІжӢ’з»қ','е»әи®®','з”іиҜ·еҗҰеҶі','ж•°жҚ®ејӮеёё','и®ҫи®ЎеҰӮжӯӨ','йңҖжұӮ']) OR d.label IS NULL)) AS p1_total,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P1' AND (NOT (d.label ?| ARRAY['еҠҹиғҪеұҸи”Ҫ','е·ІжӢ’з»қ','е»әи®®','з”іиҜ·еҗҰеҶі','ж•°жҚ®ејӮеёё','и®ҫи®ЎеҰӮжӯӨ','йңҖжұӮ']) OR d.label IS NULL) AND (d.label ? 'е·Ідҝ®еӨҚ' OR (d.label ? 'жңӘеӨҚзҺ°' AND d.defect_status = 'е·Іе…ій—ӯ'))) AS p1_fixed,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P1' AND d.defect_status = 'е·Іе…ій—ӯ') AS p1_closed,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P2' AND (NOT (d.label ?| ARRAY['еҠҹиғҪеұҸи”Ҫ','е·ІжӢ’з»қ','е»әи®®','з”іиҜ·еҗҰеҶі','ж•°жҚ®ејӮеёё','и®ҫи®ЎеҰӮжӯӨ','йңҖжұӮ']) OR d.label IS NULL)) AS p2_total,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P2' AND (NOT (d.label ?| ARRAY['еҠҹиғҪеұҸи”Ҫ','е·ІжӢ’з»қ','е»әи®®','з”іиҜ·еҗҰеҶі','ж•°жҚ®ејӮеёё','и®ҫи®ЎеҰӮжӯӨ','йңҖжұӮ']) OR d.label IS NULL) AND (d.label ? 'е·Ідҝ®еӨҚ' OR (d.label ? 'жңӘеӨҚзҺ°' AND d.defect_status = 'е·Іе…ій—ӯ'))) AS p2_fixed,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P3' AND (NOT (d.label ?| ARRAY['еҠҹиғҪеұҸи”Ҫ','е·ІжӢ’з»қ','е»әи®®','з”іиҜ·еҗҰеҶі','ж•°жҚ®ејӮеёё','и®ҫи®ЎеҰӮжӯӨ','йңҖжұӮ']) OR d.label IS NULL)) AS p3_total,\n    COUNT(d.id) FILTER (WHERE d.priority = 'P3' AND (NOT (d.label ?| ARRAY['еҠҹиғҪеұҸи”Ҫ','е·ІжӢ’з»қ','е»әи®®','з”іиҜ·еҗҰеҶі','ж•°жҚ®ејӮеёё','и®ҫи®ЎеҰӮжӯӨ','йңҖжұӮ']) OR d.label IS NULL) AND (d.label ? 'е·Ідҝ®еӨҚ' OR (d.label ? 'жңӘеӨҚзҺ°' AND d.defect_status = 'е·Іе…ій—ӯ'))) AS p3_fixed,\n\n    -- 6. дё“йЎ№з»ҶеҲҶз»ҹи®Ў\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level1' AND (d.defect ILIKE '%йҖҖ%' OR d.defect ILIKE '%еӣһйҖҖ%')) AS level_1_rollback,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level1' AND d.defect ILIKE '%жҢӮжңә%') AS level_1_hang,\n    COUNT(d.id) FILTER (WHERE d.defect_rank = 'level1' AND d.defect NOT ILIKE '%йҖҖ%' AND d.defect NOT ILIKE '%еӣһйҖҖ%' AND d.defect NOT ILIKE '%жҢӮжңә%') AS level_1_other,\n    COUNT(d.id) FILTER (WHERE d.label ? 'еӨҚжөӢжңӘйҖҡиҝҮ') AS retest_failed_count,\n    COUNT(d.id) FILTER (WHERE d.label ? 'е»¶жңҹ') AS total_delayed,\n    COUNT(d.id) FILTER (WHERE d.label ? 'е»әи®®') AS suggested_count,\n    COUNT(d.id) FILTER (WHERE d.defect_status = 'е·Ідҝ®еӨҚ') AS fixed_unupdated,\n\n    -- 7. жұҮжҖ»дёҺд»Ҡж—ҘжҢҮж Ү\n    COUNT(d.id) FILTER (WHERE d.defect_status IN ('е·Іе…ій—ӯ', 'е·Ійҳ¶ж®өжҖ§е…ій—ӯ')) AS total_closed,\n    COUNT(d.id) FILTER (WHERE d.defect_status NOT IN ('е·Іе…ій—ӯ', 'е·Ійҳ¶ж®өжҖ§е…ій—ӯ', 'ж— йңҖдҝ®еӨҚ')) AS open_count,\n    COUNT(d.id) FILTER (WHERE d.label ? 'е·Ідҝ®еӨҚ') AS total_fixed,\n    COUNT(d.id) FILTER (WHERE d.\"createdAt\"::date = CURRENT_DATE) AS new_issue_total,\n    COUNT(d.id) FILTER (WHERE d.\"createdAt\"::date = CURRENT_DATE AND d.label ? 'е·Ідҝ®еӨҚ') AS new_issue_fixed\n\nFROM defects d\nJOIN t_5yxbbcczpos m2m ON d.id = m2m.defect_id\nWHERE m2m.module_id = {{$scopes.60k98hgp2i2.item.id}};"} workflowId=351260161671168
