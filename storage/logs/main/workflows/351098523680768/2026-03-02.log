y = 'P2' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label ? '已修复' OR (label ? '未复现' AND defect_status = '已关闭'))) AS p2_fixed,\n    COUNT(id) FILTER (WHERE priority = 'P3' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS p3_total,\n    COUNT(id) FILTER (WHERE priority = 'P3' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label ? '已修复' OR (label ? '未复现' AND defect_status = '已关闭'))) AS p3_fixed,\n\n    -- 4. 专项统计 (回退/挂机/延期等)\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND (defect ILIKE '%退%' OR defect ILIKE '%回退%' OR defect ILIKE '%倒退%')) AS level_1_rollback,\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND defect ILIKE '%挂机%') AS level_1_hang,\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND (defect NOT ILIKE '%退%' AND defect NOT ILIKE '%回退%' AND defect NOT ILIKE '%倒退%' AND defect NOT ILIKE '%挂机%')) AS level_1_other,\n    COUNT(id) FILTER (WHERE label ? '复测未通过') AS retest_failed_count,\n    COUNT(id) FILTER (WHERE label ? '延期') AS total_delayed,\n    COUNT(id) FILTER (WHERE defect_status = '已修复') AS fixed_unupdated,\n    COUNT(id) FILTER (WHERE label ? '建议') AS suggested_count,\n\n    -- 5. 汇总与今日指标 (修正时间字段引号)\n    COUNT(id) FILTER (WHERE defect_status IN ('已关闭', '已阶段性关闭')) AS total_closed,\n    COUNT(id) FILTER (WHERE defect_status NOT IN ('已关闭', '已阶段性关闭', '无需修复')) AS open_count,\n    COUNT(id) FILTER (WHERE defect_status != '无需修复') AS module_total,\n    COUNT(id) FILTER (WHERE label ? '已修复') AS total_fixed,\n    COUNT(id) FILTER (WHERE \"createdAt\"::date = CURRENT_DATE) AS new_issue_total,\n    COUNT(id) FILTER (WHERE \"createdAt\"::date = CURRENT_DATE AND label ? '已修复') AS new_issue_fixed\n\nFROM defects\nWHERE f_jmazop48q5l = {{$scopes.60k98hgp2i2.item.id}};"} workflowId=351098523680768
