RE priority = 'P2' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label ? '已修复' OR (label ? '未复现' AND defect_status = '已关闭'))) AS p2_fixed,\n    COUNT(id) FILTER (WHERE priority = 'P3' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS p3_total,\n    COUNT(id) FILTER (WHERE priority = 'P3' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label ? '已修复' OR (label ? '未复现' AND defect_status = '已关闭'))) AS p3_fixed,\n\n    -- 4. 专项分类统计 (回退/挂机/复测/延期)\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND (defect_name ILIKE '%退%' OR defect_name ILIKE '%回退%' OR defect_name ILIKE '%倒退%')) AS level_1_rollback,\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND defect_name ILIKE '%挂机%') AS level_1_hang,\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND (defect_name NOT ILIKE '%退%' AND defect_name NOT ILIKE '%回退%' AND defect_name NOT ILIKE '%倒退%' AND defect_name NOT ILIKE '%挂机%')) AS level_1_other,\n    COUNT(id) FILTER (WHERE label ? '复测未通过' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS retest_failed_count,\n    COUNT(id) FILTER (WHERE label ? '延期' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS total_delayed,\n    COUNT(id) FILTER (WHERE defect_status = '已修复' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS fixed_unupdated,\n    COUNT(id) FILTER (WHERE label ? '建议') AS suggested_count,\n\n    -- 5. 汇总与今日统计\n    COUNT(id) FILTER (WHERE defect_status IN ('已关闭', '已阶段性关闭') AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS total_closed,\n    COUNT(id) FILTER (WHERE defect_status NOT IN ('已关闭', '已阶段性关闭', '无需修复') AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS open_count,\n    COUNT(id) FILTER (WHERE defect_status != '无需修复') AS module_total,\n    COUNT(id) FILTER (WHERE label ? '已修复') AS total_fixed,\n    COUNT(id) FILTER (WHERE created_at::date = CURRENT_DATE AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS new_issue_total,\n    COUNT(id) FILTER (WHERE created_at::date = CURRENT_DATE AND label ? '已修复') AS new_issue_fixed\n\nFROM defects\n-- 恢复自适应变量，不要填死 ID\nWHERE f_jmazop48q5l = '{{$context.data.f_jmazop48q5l}}'\nGROUP BY f_jmazop48q5l;"} workflowId=351092607614976
