[32m2026-03-02 15:42:57 [info]  response /api/flow_nodes:update?filterByTk=351091284312064[39m method=POST path=/api/flow_nodes:update?filterByTk=351091284312064 res={"status":200} action={"actionName":"update","resourceName":"flow_nodes","params":{"filterByTk":"351091284312064","resourceName":"flow_nodes","actionName":"update","values":{"config":{"dataSource":"main","sql":"SELECT\n    -- 1. 一级缺陷 (Level 1)\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS level_1_count,\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label @> ARRAY['已修复']::varchar[] OR (label @> ARRAY['未复现']::varchar[] AND defect_status = '已关闭'))) AS level_1_fixed,\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND (defect_name ILIKE '%退%' OR defect_name ILIKE '%回退%' OR defect_name ILIKE '%倒退%')) AS level_1_rollback,\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND defect_name ILIKE '%挂机%') AS level_1_hang,\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND defect_name NOT ILIKE '%退%' AND defect_name NOT ILIKE '%回退%' AND defect_name NOT ILIKE '%倒退%' AND defect_name NOT ILIKE '%挂机%') AS level_1_other,\n\n    -- 2. 二级/三级缺陷 (Level 2 & 3)\n    COUNT(id) FILTER (WHERE defect_rank = '二级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS level_2_count,\n    COUNT(id) FILTER (WHERE defect_rank = '二级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label @> ARRAY['已修复']::varchar[] OR (label @> ARRAY['未复现']::varchar[] AND defect_status = '已关闭'))) AS level_2_fixed,\n    COUNT(id) FILTER (WHERE defect_rank = '三级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS level_3_count,\n    COUNT(id) FILTER (WHERE defect_rank = '三级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label @> ARRAY['已修复']::varchar[] OR (label @> ARRAY['未复现']::varchar[] AND defect_status = '已关闭'))) AS level_3_fixed,\n\n    -- 3. 优先级统计 (P1/P2/P3)\n    COUNT(id) FILTER (WHERE priority = 'P1' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS p1_total,\n    COUNT(id) FILTER (WHERE priority = 'P1' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label @> ARRAY['已修复']::varchar[] OR (label @> ARRAY['未复现']::varchar[] AND defect_status = '已关闭'))) AS p1_fixed,\n    COUNT(id) FILTER (WHERE priority = 'P1' AND defect_status = '已关闭') AS p1_closed,\n    COUNT(id) FILTER (WHERE priority = 'P2' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS p2_total,\n    COUNT(id) FILTER (WHERE priority = 'P2' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label @> ARRAY['已修复']::varchar[] OR (label @> ARRAY['未复现']::varchar[] AND defect_status = '已关闭'))) AS p2_fixed,\n    COUNT(id) FILTER (WHERE priority = 'P3' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS p3_total,\n    COUNT(id) FILTER (WHERE priority = 'P3' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label @> ARRAY['已修复']::varchar[] OR (label @> ARRAY['未复现']::varchar[] AND defect_status = '已关闭'))) AS p3_fixed,\n\n    -- 4. 专项指标\n    COUNT(id) FILTER (WHERE defect_status IN ('已关闭', '已阶段性关闭') AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS total_closed,\n    COUNT(id) FILTER (WHERE label @> ARRAY['延期']::varchar[] AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS total_delayed,\n    COUNT(id) FILTER (WHERE defect_status NOT IN ('已关闭', '已阶段性关闭', '无需修复') AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS open_count,\n    COUNT(id) FILTER (WHERE label @> ARRAY['复测未通过']::varchar[] AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS retest_failed_count,\n    COUNT(id) FILTER (WHERE defect_status != '无需修复') AS module_total,\n    COUNT(id) FILTER (WHERE label @> ARRAY['已修复']::varchar[]) AS total_fixed,\n    COUNT(id) FILTER (WHERE label @> ARRAY['建议']::varchar[]) AS suggested_count,\n    COUNT(id) FILTER (WHERE defect_status = '已修复' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS fixed_unupdated,\n\n    -- 5. 今日新增\n    COUNT(id) FILTER (WHERE created_at::date = CURRENT_DATE AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS new_issue_total,\n    COUNT(id) FILTER (WHERE created_at::date = CURRENT_DATE AND label @> ARRAY['已修复']::varchar[]) AS new_issue_fixed\n\nFROM defects\nWHERE f_jmazop48q5l = '{{$context.data.f_jmazop48q5l}}';"}}}} userId=1 username=nocobase status=200 cost=7 app=main reqId=c84fb3d0-d699-463a-ab03-c6ac2134cc9b bodySize=6015
