[32m2026-03-02 16:28:09 [info]  response /api/flow_nodes:update?filterByTk=351096931942402[39m method=POST path=/api/flow_nodes:update?filterByTk=351096931942402 res={"status":200} action={"actionName":"update","resourceName":"flow_nodes","params":{"filterByTk":"351096931942402","resourceName":"flow_nodes","actionName":"update","values":{"config":{"dataSource":"main","sql":"SELECT\n    -- 1. 基础定位 ID\n    f_jmazop48q5l AS id,\n\n    -- 2. 缺陷等级统计 (L1/L2/L3)\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS level_1_count,\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label ? '已修复' OR (label ? '未复现' AND defect_status = '已关闭'))) AS level_1_fixed,\n    COUNT(id) FILTER (WHERE defect_rank = '二级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS level_2_count,\n    COUNT(id) FILTER (WHERE defect_rank = '二级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label ? '已修复' OR (label ? '未复现' AND defect_status = '已关闭'))) AS level_2_fixed,\n    COUNT(id) FILTER (WHERE defect_rank = '三级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS level_3_count,\n    COUNT(id) FILTER (WHERE defect_rank = '三级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label ? '已修复' OR (label ? '未复现' AND defect_status = '已关闭'))) AS level_3_fixed,\n\n    -- 3. 优先级统计 (P1/P2/P3)\n    COUNT(id) FILTER (WHERE priority = 'P1' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS p1_total,\n    COUNT(id) FILTER (WHERE priority = 'P1' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label ? '已修复' OR (label ? '未复现' AND defect_status = '已关闭'))) AS p1_fixed,\n    COUNT(id) FILTER (WHERE priority = 'P1' AND defect_status = '已关闭') AS p1_closed,\n    COUNT(id) FILTER (WHERE priority = 'P2' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS p2_total,\n    COUNT(id) FILTER (WHERE priority = 'P2' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label ? '已修复' OR (label ? '未复现' AND defect_status = '已关闭'))) AS p2_fixed,\n    COUNT(id) FILTER (WHERE priority = 'P3' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS p3_total,\n    COUNT(id) FILTER (WHERE priority = 'P3' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label ? '已修复' OR (label ? '未复现' AND defect_status = '已关闭'))) AS p3_fixed,\n\n    -- 4. 专项统计 (回退/挂机/延期等)\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND (defect ILIKE '%退%' OR defect ILIKE '%回退%' OR defect ILIKE '%倒退%')) AS level_1_rollback,\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND defect ILIKE '%挂机%') AS level_1_hang,\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND (defect NOT ILIKE '%退%' AND defect NOT ILIKE '%回退%' AND defect NOT ILIKE '%倒退%' AND defect NOT ILIKE '%挂机%')) AS level_1_other,\n    COUNT(id) FILTER (WHERE label ? '复测未通过') AS retest_failed_count,\n    COUNT(id) FILTER (WHERE label ? '延期') AS total_delayed,\n    COUNT(id) FILTER (WHERE defect_status = '已修复') AS fixed_unupdated,\n    COUNT(id) FILTER (WHERE label ? '建议') AS suggested_count,\n\n    -- 5. 汇总与今日指标\n    COUNT(id) FILTER (WHERE defect_status IN ('已关闭', '已阶段性关闭')) AS total_closed,\n    COUNT(id) FILTER (WHERE defect_status NOT IN ('已关闭', '已阶段性关闭', '无需修复')) AS open_count,\n    COUNT(id) FILTER (WHERE defect_status != '无需修复') AS module_total,\n    COUNT(id) FILTER (WHERE label ? '已修复') AS total_fixed,\n    COUNT(id) FILTER (WHERE \"createdAt\"::date = CURRENT_DATE) AS new_issue_total,\n    COUNT(id) FILTER (WHERE \"createdAt\"::date = CURRENT_DATE AND label ? '已修复') AS new_issue_fixed\n\nFROM defects\n-- 核心修正：移除单引号，通过变量拾取器重新选择 ID\nWHERE f_jmazop48q5l = {{$node.r29iolespw0.id}}\nGROUP BY f_jmazop48q5l;"}}}} userId=1 username=nocobase status=200 cost=41 app=main reqId=e9996a19-1c29-4e65-beed-282c3ced82ae bodySize=4992
