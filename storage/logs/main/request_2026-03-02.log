[32m2026-03-02 15:38:02 [info]  response /api/flow_nodes:update?filterByTk=351089281531904[39m method=POST path=/api/flow_nodes:update?filterByTk=351089281531904 res={"status":200} action={"actionName":"update","resourceName":"flow_nodes","params":{"filterByTk":"351089281531904","resourceName":"flow_nodes","actionName":"update","values":{"config":{"dataSource":"main","sql":"SELECT \n    -- 【1. 基础汇总类】\n    COUNT(id) AS absolute_total, -- 物理总数\n    COUNT(id) FILTER (WHERE f_jmazop48q5l IS NOT NULL AND (defect_status != '无需修复' OR defect_status IS NULL)) AS module_total, -- 模块总缺陷数\n    COUNT(id) FILTER (WHERE label @> ARRAY['已修复']::varchar[]) AS module_fixed_total, -- 模块总修复数\n    COUNT(id) FILTER (WHERE (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS total_valid, -- 全项目有效总数\n    COUNT(id) FILTER (WHERE defect_status = '已阶段性关闭' OR defect_status = '已关闭' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS total_closed, -- 缺陷关闭总数\n\n    -- 【2. 等级维度统计 (L1/L2/L3)】\n    -- 一级缺陷\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS l1_total,\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label @> ARRAY['已修复']::varchar[] OR (label @> ARRAY['未复现']::varchar[] AND defect_status = '已关闭'))) AS l1_fixed,\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND (defect_name ILIKE '%退%' OR defect_name ILIKE '%回退%' OR defect_name ILIKE '%倒退%')) AS l1_rollback,\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND defect_name ILIKE '%挂机%') AS l1_hang,\n    COUNT(id) FILTER (WHERE defect_rank = '一级' AND (defect_name NOT ILIKE '%退%' AND defect_name NOT ILIKE '%回退%' AND defect_name NOT ILIKE '%倒退%' AND defect_name NOT ILIKE '%挂机%')) AS l1_other,\n    \n    -- 二级缺陷\n    COUNT(id) FILTER (WHERE defect_rank = '二级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS l2_total,\n    COUNT(id) FILTER (WHERE defect_rank = '二级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label @> ARRAY['已修复']::varchar[] OR (label @> ARRAY['未复现']::varchar[] AND defect_status = '已关闭'))) AS l2_fixed,\n    \n    -- 三级缺陷\n    COUNT(id) FILTER (WHERE defect_rank = '三级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS l3_total,\n    COUNT(id) FILTER (WHERE defect_rank = '三级' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label @> ARRAY['已修复']::varchar[] OR (label @> ARRAY['未复现']::varchar[] AND defect_status = '已关闭'))) AS l3_fixed,\n\n    -- 【3. 优先级维度统计 (P1/P2/P3)】\n    -- P1 缺陷\n    COUNT(id) FILTER (WHERE priority = 'P1' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS p1_total,\n    COUNT(id) FILTER (WHERE priority = 'P1' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label @> ARRAY['已修复']::varchar[] OR (label @> ARRAY['未复现']::varchar[] AND defect_status = '已关闭'))) AS p1_fixed,\n    COUNT(id) FILTER (WHERE priority = 'P1' AND defect_status = '已关闭') AS p1_closed,\n    \n    -- P2/P3 缺陷\n    COUNT(id) FILTER (WHERE priority = 'P2' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS p2_total,\n    COUNT(id) FILTER (WHERE priority = 'P2' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label @> ARRAY['已修复']::varchar[] OR (label @> ARRAY['未复现']::varchar[] AND defect_status = '已关闭'))) AS p2_fixed,\n    COUNT(id) FILTER (WHERE priority = 'P3' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS p3_total,\n    COUNT(id) FILTER (WHERE priority = 'P3' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL) AND (label @> ARRAY['已修复']::varchar[] OR (label @> ARRAY['未复现']::varchar[] AND defect_status = '已关闭'))) AS p3_fixed,\n\n    -- 【4. 专项指标统计】\n    COUNT(id) FILTER (WHERE label @> ARRAY['延期']::varchar[] AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS total_delayed, -- 延期总数\n    COUNT(id) FILTER (WHERE defect_status NOT IN ('已阶段性关闭', '已关闭', '无需修复') AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS unclosed_count, -- 未关闭个数\n    COUNT(id) FILTER (WHERE label @> ARRAY['复测未通过']::varchar[] AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS retest_failed, -- 复测未通过\n    COUNT(id) FILTER (WHERE defect_status = '已修复' AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS fixed_unupdated, -- 已修复/未更新\n    COUNT(id) FILTER (WHERE label @> ARRAY['建议']::varchar[]) AS suggested_count, -- 建议类\n\n    -- 【5. 时间维度统计 (今日新增)】\n    COUNT(id) FILTER (WHERE created_at::date = CURRENT_DATE AND (NOT (label ?| ARRAY['功能屏蔽','已拒绝','建议','申请否决','数据异常','设计如此','需求']) OR label IS NULL)) AS today_total, -- 今日新发总数\n    COUNT(id) FILTER (WHERE created_at::date = CURRENT_DATE AND label @> ARRAY['已修复']::varchar[]) AS today_fixed -- 今日新发已修复\n\nFROM defects \nWHERE f_jmazop48q5l = '{{$context.data.f_jmazop48q5l}}';"}}}} userId=1 username=nocobase status=200 cost=41 app=main reqId=b550b7b8-459f-4b67-a90d-cc020398ed30 bodySize=6670
