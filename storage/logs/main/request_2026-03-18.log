[32m2026-03-18 15:59:57 [info]  response /api/flow_nodes:update?filterByTk=353992515190785[39m method=POST path=/api/flow_nodes:update?filterByTk=353992515190785 res={"status":200} action={"actionName":"update","resourceName":"flow_nodes","params":{"filterByTk":"353992515190785","resourceName":"flow_nodes","actionName":"update","values":{"config":{"dataSource":"main","sql":"/* 直接使用 INSERT ... ON CONFLICT 逻辑 */\nINSERT INTO \"defects_reason\" (\n    \"id\",\n    \"createdAt\",\n    \"updatedAt\",\n    \"review_id\",\n    \"module_id\",\n    \"count_requirement\", \n    \"count_design\", \n    \"count_coding\", \n    \"count_package\", \n    \"count_dependency\"\n)\nSELECT \n    -- 只有在新建时才生成 ID，更新时不改 ID\n    (extract(epoch from now()) * 1000 + floor(random() * 1000))::bigint,\n    NOW(),\n    NOW(),\n    t1.\"f_0ipjqjhd3dt\",\n    t1.\"f_jmazop48q5l\",\n    SUM(CASE WHEN t1.\"level_1_cause\" = '需求问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '设计问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '编码规范' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '打包问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '依赖问题' THEN 1 ELSE 0 END)\nFROM \"defects\" AS t1\nWHERE t1.\"f_0ipjqjhd3dt\" = {{ $context.data.f_0ipjqjhd3dt }}\nGROUP BY t1.\"f_jmazop48q5l\", t1.\"f_0ipjqjhd3dt\"\n\n/* 关键：如果 review_id 和 module_id 已经存在，则只更新数字 */\nON CONFLICT (\"review_id\", \"module_id\") \nDO UPDATE SET \n    \"count_requirement\" = EXCLUDED.count_requirement,\n    \"count_design\" = EXCLUDED.count_design,\n    \"count_coding\" = EXCLUDED.count_coding,\n    \"count_package\" = EXCLUDED.count_package,\n    \"count_dependency\" = EXCLUDED.count_dependency,\n    \"updatedAt\" = NOW();"}}}} userId=1 username=nocobase status=200 cost=8 app=main reqId=c2a79a1e-bca3-4bc0-8b5d-53934e75cf6a bodySize=1770
