[32m2026-03-18 16:33:26 [info]  response /api/flow_nodes:update?filterByTk=353996749340673[39m method=POST path=/api/flow_nodes:update?filterByTk=353996749340673 res={"status":200} action={"actionName":"update","resourceName":"flow_nodes","params":{"filterByTk":"353996749340673","resourceName":"flow_nodes","actionName":"update","values":{"config":{"dataSource":"main","sql":"/* 1. 清理汇总表旧数据 */\nDELETE FROM \"defects_reason\" \nWHERE \"review_id\" = {{ $context.data.f_0ipjqjhd3dt }}; \n\n/* 2. 统计并重新插入 */\nINSERT INTO \"defects_reason\" (\n    \"id\",\n    \"createdAt\",\n    \"updatedAt\",\n    \"review_id\",\n    \"module_id\", -- 👈 目标：存入正确的模块汇总 ID\n    \"count_requirement\", \n    \"count_design\", \n    \"count_coding\", \n    \"count_package\", \n    \"count_dependency\"\n)\nSELECT \n    (extract(epoch from now()) * 1000 + floor(random() * 1000))::bigint,\n    NOW(),\n    NOW(),\n    t1.\"f_0ipjqjhd3dt\",\n    -- 👇 核心修正：这里必须填入变量，且后面紧跟逗号\n    {{ $context.data.review_ref.module_id }}, \n    SUM(CASE WHEN t1.\"level_1_cause\" = '需求问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '设计问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '编码规范' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '打包问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '依赖问题' THEN 1 ELSE 0 END)\nFROM \"defects\" AS t1\nWHERE t1.\"f_0ipjqjhd3dt\" = {{ $context.data.f_0ipjqjhd3dt }} \nGROUP BY t1.\"f_0ipjqjhd3dt\";"}}}} userId=1 username=nocobase status=200 cost=8 app=main reqId=ecc3e22b-b415-45b7-807f-0d74c28c2993 bodySize=1520
