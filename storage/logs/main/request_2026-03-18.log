[32m2026-03-18 15:59:52 [info]  response /api/workflows:update?filterByTk=353637939216384[39m method=POST path=/api/workflows:update?filterByTk=353637939216384 res={"status":200} action={"actionName":"update","resourceName":"workflows","params":{"filterByTk":"353637939216384","resourceName":"workflows","actionName":"update","values":{"id":353637939216384,"createdAt":"2026-03-16T09:01:49.719Z","updatedAt":"2026-03-16T09:03:38.933Z","key":"8alcozhoboc","title":"缺陷原因汇总增加更新","enabled":false,"description":null,"type":"collection","triggerTitle":null,"executed":0,"allExecuted":0,"current":true,"sync":false,"options":{"stackLimit":1,"deleteExecutionOnStatus":[]},"nodes":[{"id":353637939216385,"createdAt":"2026-03-16T09:01:49.731Z","updatedAt":"2026-03-16T09:01:52.709Z","key":"if7j7gptm8l","title":"SQL 操作","upstreamId":null,"branchIndex":null,"downstreamId":null,"type":"sql","config":{"dataSource":"main","sql":"/* 1. 清理汇总表旧数据 */\n-- 使用动态变量替换 456\nDELETE FROM \"defects_reason\" \nWHERE \"review_id\" = {{ $context.data.f_0ipjqjhd3dt }}; \n\n/* 2. 统计并重新插入 */\nINSERT INTO \"defects_reason\" (\n    \"id\",\n    \"createdAt\",\n    \"updatedAt\",\n    \"review_id\",\n    \"module_id\",\n    \"count_requirement\", \n    \"count_design\", \n    \"count_coding\", \n    \"count_package\", \n    \"count_dependency\"\n)\nSELECT \n    -- 动态生成 ID：(当前时间戳 * 1000 + 0-999随机数)\n    (extract(epoch from now()) * 1000 + floor(random() * 1000))::bigint,\n    NOW(),\n    NOW(),\n    t1.\"f_0ipjqjhd3dt\", -- 评审外键\n    t1.\"f_jmazop48q5l\", -- 模块外键\n    SUM(CASE WHEN t1.\"level_1_cause\" = '需求问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '设计问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '编码规范' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '打包问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '依赖问题' THEN 1 ELSE 0 END)\nFROM \"defects\" AS t1\n-- 👈 这里的 456 也要换成动态变量\nWHERE t1.\"f_0ipjqjhd3dt\" = {{ $context.data.f_0ipjqjhd3dt }} \nGROUP BY t1.\"f_jmazop48q5l\", t1.\"f_0ipjqjhd3dt\";"},"workflowId":353637939216384}],"revisions":[{"id":353635793829888,"createdAt":"2026-03-16T08:44:46.845Z","updatedAt":"2026-03-16T08:50:18.086Z","key":"8alcozhoboc","title":"测试","enabled":false,"description":null,"type":"collection","triggerTitle":null,"config":{"mode":3,"appends":["review_ref"],"changed":[],"condition":{"$and":[]},"collection":"defects"},"executed":0,"allExecuted":0,"current":null,"sync":false,"options":{"stackLimit":1,"deleteExecutionOnStatus":[]}},{"id":353636477501440,"createdAt":"2026-03-16T08:50:12.807Z","updatedAt":"2026-03-16T08:57:03.047Z","key":"8alcozhoboc","title":"测试","enabled":false,"description":null,"type":"collection","triggerTitle":null,"config":{"mode":3,"appends":["review_ref"],"changed":[],"condition":{"$and":[]},"collection":"defects"},"executed":0,"allExecuted":0,"current":null,"sync":false,"options":{"stackLimit":1,"deleteExecutionOnStatus":[]}},{"id":353637326848000,"createdAt":"2026-03-16T08:56:57.630Z","updatedAt":"2026-03-16T08:59:48.549Z","key":"8alcozhoboc","title":"测试","enabled":false,"description":null,"type":"collection","triggerTitle":null,"config":{"mode":3,"appends":["review_ref"],"changed":[],"condition":{"$and":[]},"collection":"defects"},"executed":0,"allExecuted":0,"current":null,"sync":false,"options":{"stackLimit":1,"deleteExecutionOnStatus":[]}},{"id":353637668683776,"createdAt":"2026-03-16T08:59:40.305Z","updatedAt":"2026-03-16T09:01:54.439Z","key":"8alcozhoboc","title":"测试","enabled":false,"description":null,"type":"collection","triggerTitle":null,"config":{"mode":3,"appends":["review_ref"],"changed":[],"condition":{"$and":[]},"collection":"defects"},"executed":0,"allExecuted":0,"current":null,"sync":false,"options":{"stackLimit":1,"deleteExecutionOnStatus":[]}},{"id":353637939216384,"createdAt":"2026-03-16T09:01:49.719Z","updatedAt":"2026-03-16T09:03:38.933Z","key":"8alcozhoboc","title":"缺陷原因汇总增加更新","enabled":true,"description":null,"type":"collection