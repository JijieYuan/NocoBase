[32m2026-03-18 16:10:30 [info]  response /api/flow_nodes:update?filterByTk=353993863659521[39m method=POST path=/api/flow_nodes:update?filterByTk=353993863659521 res={"status":200} action={"actionName":"update","resourceName":"flow_nodes","params":{"filterByTk":"353993863659521","resourceName":"flow_nodes","actionName":"update","values":{"config":{"dataSource":"main","sql":"/* 1. 清理汇总表旧数据 */\nDELETE FROM \"defects_reason\" \nWHERE \"review_id\" = {{ $context.data.f_0ipjqjhd3dt }}; \n\n/* 2. 统计并重新插入 */\nINSERT INTO \"defects_reason\" (\n    \"id\",\n    \"createdAt\",\n    \"updatedAt\",\n    \"review_id\",\n    \"module_id\",\n    \"module_name\", -- 👈 目标：汇总表里的字符串字段\n    \"count_requirement\", \n    \"count_design\", \n    \"count_coding\", \n    \"count_package\", \n    \"count_dependency\"\n)\nSELECT \n    (extract(epoch from now()) * 1000 + floor(random() * 1000))::bigint,\n    NOW(),\n    NOW(),\n    t1.\"f_0ipjqjhd3dt\",\n    t1.\"f_jmazop48q5l\",\n    m.\"name\", -- 👈 核心：从模块表里拿到的字符串（例如“工程图”）\n    SUM(CASE WHEN t1.\"level_1_cause\" = '需求问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '设计问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '编码规范' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '打包问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '依赖问题' THEN 1 ELSE 0 END)\nFROM \"defects\" AS t1\n-- 👈 这里需要 JOIN 一下，拿到 ID 对应的名字\nLEFT JOIN \"modules\" AS m ON t1.\"f_jmazop48q5l\" = m.\"id\" \nWHERE t1.\"f_0ipjqjhd3dt\" = {{ $context.data.f_0ipjqjhd3dt }} \n-- 👈 重点：SELECT 里多了 m.\"name\"，GROUP BY 里也必须加上，否则 SQL 会报错\nGROUP BY t1.\"f_jmazop48q5l\", t1.\"f_0ipjqjhd3dt\", m.\"name\";"}}}} userId=1 username=nocobase status=200 cost=8 app=main reqId=e86af28d-2803-4813-9319-b98fa43a81a4 bodySize=1798
