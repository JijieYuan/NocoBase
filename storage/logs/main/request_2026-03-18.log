[32m2026-03-18 16:31:43 [info]  response /api/flow_nodes:update?filterByTk=353996527042561[39m method=POST path=/api/flow_nodes:update?filterByTk=353996527042561 res={"status":200} action={"actionName":"update","resourceName":"flow_nodes","params":{"filterByTk":"353996527042561","resourceName":"flow_nodes","actionName":"update","values":{"config":{"dataSource":"main","sql":"/* 1. 清理汇总表旧数据 */\nDELETE FROM \"defects_reason\" \nWHERE \"review_id\" = {{ $context.data.f_0ipjqjhd3dt }}; \n\n/* 2. 统计并重新插入 */\nINSERT INTO \"defects_reason\" (\n    \"id\",\n    \"createdAt\",\n    \"updatedAt\",\n    \"review_id\",\n    \"module_id\",\n    \"count_requirement\", \n    \"count_design\", \n    \"count_coding\", \n    \"count_package\", \n    \"count_dependency\"\n)\nSELECT \n    (extract(epoch from now()) * 1000 + floor(random() * 1000))::bigint,\n    NOW(),\n    NOW(),\n    t1.\"f_0ipjqjhd3dt\",\n    -- 👈 修改点：直接使用关联评审表中的正确模块 ID\n    -- 在 NocoBase SQL 节点中，你可以尝试引用这个变量\n    {{ $context.data.review_ref.module_id }}, \n    SUM(CASE WHEN t1.\"level_1_cause\" = '需求问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '设计问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '编码规范' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '打包问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '依赖问题' THEN 1 ELSE 0 END)\nFROM \"defects\" AS t1\nWHERE t1.\"f_0ipjqjhd3dt\" = {{ $context.data.f_0ipjqjhd3dt }} \n-- 👈 注意：GROUP BY 也只需保留 review_id 即可（因为 module_id 现在是常量变量）\nGROUP BY t1.\"f_0ipjqjhd3dt\";"}}}} userId=1 username=nocobase status=200 cost=9 app=main reqId=e6b8a55c-c603-42d1-aec6-f511fe40b37d bodySize=1644
