[32m2026-03-18 16:35:57 [info]  response /api/workflows:update?filterByTk=353996749340672[39m method=POST path=/api/workflows:update?filterByTk=353996749340672 res={"status":200} action={"actionName":"update","resourceName":"workflows","params":{"filterByTk":"353996749340672","resourceName":"workflows","actionName":"update","values":{"id":353996749340672,"createdAt":"2026-03-18T08:33:23.079Z","updatedAt":"2026-03-18T08:33:28.121Z","key":"7oohsord1hg","title":"测试删除","enabled":false,"description":null,"type":"collection","triggerTitle":null,"executed":0,"allExecuted":0,"current":true,"sync":false,"options":{"stackLimit":1,"deleteExecutionOnStatus":[]},"nodes":[{"id":353996749340673,"createdAt":"2026-03-18T08:33:23.082Z","updatedAt":"2026-03-18T08:33:26.574Z","key":"4ay0hlakw2y","title":"SQL 操作","upstreamId":null,"branchIndex":null,"downstreamId":null,"type":"sql","config":{"dataSource":"main","sql":"/* 1. 清理汇总表旧数据 */\nDELETE FROM \"defects_reason\" \nWHERE \"review_id\" = {{ $context.data.f_0ipjqjhd3dt }}; \n\n/* 2. 统计并重新插入 */\nINSERT INTO \"defects_reason\" (\n    \"id\",\n    \"createdAt\",\n    \"updatedAt\",\n    \"review_id\",\n    \"module_id\", -- 👈 目标：存入正确的模块汇总 ID\n    \"count_requirement\", \n    \"count_design\", \n    \"count_coding\", \n    \"count_package\", \n    \"count_dependency\"\n)\nSELECT \n    (extract(epoch from now()) * 1000 + floor(random() * 1000))::bigint,\n    NOW(),\n    NOW(),\n    t1.\"f_0ipjqjhd3dt\",\n    -- 👇 核心修正：这里必须填入变量，且后面紧跟逗号\n    {{ $context.data.review_ref.module_id }}, \n    SUM(CASE WHEN t1.\"level_1_cause\" = '需求问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '设计问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '编码规范' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '打包问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '依赖问题' THEN 1 ELSE 0 END)\nFROM \"defects\" AS t1\nWHERE t1.\"f_0ipjqjhd3dt\" = {{ $context.data.f_0ipjqjhd3dt }} \nGROUP BY t1.\"f_0ipjqjhd3dt\";"},"workflowId":353996749340672}],"revisions":[{"id":353996527042560,"createdAt":"2026-03-18T08:31:37.163Z","updatedAt":"2026-03-18T08:33:28.122Z","key":"7oohsord1hg","title":"测试删除","enabled":false,"description":null,"type":"collection","triggerTitle":null,"config":{"mode":4,"changed":[],"collection":"defects"},"executed":0,"allExecuted":0,"current":null,"sync":false,"options":{"stackLimit":1,"deleteExecutionOnStatus":[]}},{"id":353996749340672,"createdAt":"2026-03-18T08:33:23.079Z","updatedAt":"2026-03-18T08:33:28.121Z","key":"7oohsord1hg","title":"测试删除","enabled":true,"description":null,"type":"collection","triggerTitle":null,"config":{"mode":4,"changed":[],"collection":"defects"},"executed":0,"allExecuted":0,"current":true,"sync":false,"options":{"stackLimit":1,"deleteExecutionOnStatus":[]}}],"stats":{"createdAt":"2026-03-18T08:31:37.175Z","updatedAt":"2026-03-18T08:34:50.764Z","key":"7oohsord1hg","executed":3},"versionStats":{"createdAt":"2026-03-18T08:33:23.081Z","updatedAt":"2026-03-18T08:34:50.764Z","id":353996749340672,"executed":2},"categories":[]},"whitelist":["title","description","enabled","triggerTitle","config","options","categories"]}} userId=1 username=nocobase status=200 cost=17 app=main reqId=125df8ce-7235-4b5d-a7b2-84cff959441b bodySize=414
