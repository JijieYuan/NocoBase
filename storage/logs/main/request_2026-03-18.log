[32m2026-03-18 16:36:05 [info]  response /api/workflows:update?filterByTk=353638482378752[39m method=POST path=/api/workflows:update?filterByTk=353638482378752 res={"status":200} action={"actionName":"update","resourceName":"workflows","params":{"filterByTk":"353638482378752","resourceName":"workflows","actionName":"update","values":{"id":353638482378752,"createdAt":"2026-03-16T09:06:08.603Z","updatedAt":"2026-03-18T08:31:55.159Z","key":"pwydszb3x96","title":"缺陷原因汇总删除","enabled":true,"description":null,"type":"collection","triggerTitle":null,"executed":0,"allExecuted":0,"current":true,"sync":false,"options":{"stackLimit":1,"deleteExecutionOnStatus":[]},"nodes":[{"id":353638520127488,"createdAt":"2026-03-16T09:06:26.114Z","updatedAt":"2026-03-16T09:06:28.636Z","key":"4ay0hlakw2y","title":"SQL 操作","upstreamId":null,"branchIndex":null,"downstreamId":null,"type":"sql","config":{"dataSource":"main","sql":"/* 1. 清理汇总表旧数据 */\n-- 使用动态变量替换 456\nDELETE FROM \"defects_reason\" \nWHERE \"review_id\" = {{ $context.data.f_0ipjqjhd3dt }}; \n\n/* 2. 统计并重新插入 */\nINSERT INTO \"defects_reason\" (\n    \"id\",\n    \"createdAt\",\n    \"updatedAt\",\n    \"review_id\",\n    \"module_id\",\n    \"count_requirement\", \n    \"count_design\", \n    \"count_coding\", \n    \"count_package\", \n    \"count_dependency\"\n)\nSELECT \n    -- 动态生成 ID：(当前时间戳 * 1000 + 0-999随机数)\n    (extract(epoch from now()) * 1000 + floor(random() * 1000))::bigint,\n    NOW(),\n    NOW(),\n    t1.\"f_0ipjqjhd3dt\", -- 评审外键\n    t1.\"f_jmazop48q5l\", -- 模块外键\n    SUM(CASE WHEN t1.\"level_1_cause\" = '需求问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '设计问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '编码规范' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '打包问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '依赖问题' THEN 1 ELSE 0 END)\nFROM \"defects\" AS t1\n-- 👈 这里的 456 也要换成动态变量\nWHERE t1.\"f_0ipjqjhd3dt\" = {{ $context.data.f_0ipjqjhd3dt }} \nGROUP BY t1.\"f_jmazop48q5l\", t1.\"f_0ipjqjhd3dt\";"},"workflowId":353638482378752}],"revisions":[{"id":353638482378752,"createdAt":"2026-03-16T09:06:08.603Z","updatedAt":"2026-03-18T08:31:55.159Z","key":"pwydszb3x96","title":"缺陷原因汇总删除","enabled":false,"description":null,"type":"collection","triggerTitle":null,"config":{"mode":4,"changed":[],"collection":"defects"},"executed":0,"allExecuted":0,"current":true,"sync":false,"options":{"stackLimit":1,"deleteExecutionOnStatus":[]}}],"stats":{"createdAt":"2026-03-16T09:06:08.610Z","updatedAt":"2026-03-18T08:27:59.167Z","key":"pwydszb3x96","executed":14},"versionStats":{"createdAt":"2026-03-16T09:06:08.611Z","updatedAt":"2026-03-18T08:27:59.168Z","id":353638482378752,"executed":14},"categories":[]},"whitelist":["title","description","enabled","triggerTitle","config","options","categories"]}} userId=1 username=nocobase status=200 cost=9 app=main reqId=db18e55b-64be-4fd3-a27b-d0c91bfe561f bodySize=425
