[32m2026-03-18 16:27:45 [info]  response /api/flow_nodes:update?filterByTk=353996023726081[39m method=POST path=/api/flow_nodes:update?filterByTk=353996023726081 res={"status":200} action={"actionName":"update","resourceName":"flow_nodes","params":{"filterByTk":"353996023726081","resourceName":"flow_nodes","actionName":"update","values":{"config":{"dataSource":"main","sql":"/* 1. 清理汇总表旧数据 */\nDELETE FROM \"defects_reason\" \nWHERE \"review_id\" = {{ $context.data.f_0ipjqjhd3dt }}; \n\n/* 2. 统计并重新插入 */\nINSERT INTO \"defects_reason\" (\n    \"id\",\n    \"createdAt\",\n    \"updatedAt\",\n    \"review_id\",\n    \"module_id\", -- 👈 这里的 ID 必须是“模块汇总表”里真实存在的 ID\n    \"count_requirement\", \n    \"count_design\", \n    \"count_coding\", \n    \"count_package\", \n    \"count_dependency\"\n)\nSELECT \n    (extract(epoch from now()) * 1000 + floor(random() * 1000))::bigint,\n    NOW(),\n    NOW(),\n    t1.\"f_0ipjqjhd3dt\",\n    r.\"module_id\", -- 👈 核心修正：不再用 t1.f_jmazop48q5l，改用评审表里的 module_id\n    SUM(CASE WHEN t1.\"level_1_cause\" = '需求问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '设计问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '编码规范' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '打包问题' THEN 1 ELSE 0 END),\n    SUM(CASE WHEN t1.\"level_1_cause\" = '依赖问题' THEN 1 ELSE 0 END)\nFROM \"defects\" AS t1\n-- 👈 关联评审表以获取正确的模块汇总 ID\nLEFT JOIN \"review_records\" AS r ON t1.\"f_0ipjqjhd3dt\" = r.\"id\" \nWHERE t1.\"f_0ipjqjhd3dt\" = {{ $context.data.f_0ipjqjhd3dt }} \n-- 👈 注意：GROUP BY 也要同步修改\nGROUP BY r.\"module_id\", t1.\"f_0ipjqjhd3dt\";"}}}} userId=1 username=nocobase status=200 cost=8 app=main reqId=f1617f55-61c0-45dc-9a0f-b388cbeb0d02 bodySize=1718
