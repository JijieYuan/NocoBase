{
  "name": "my-nocobase-app",
  "private": true,
  "workspaces": [
    "packages/*/*",
    "packages/*/*/*",
    "packages/*/*",
    "packages/*/*/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "nocobase": "node scripts/run-node20.cjs ./node_modules/@nocobase/cli/bin/index.js",
    "pm": "node scripts/run-node20.cjs ./node_modules/@nocobase/cli/bin/index.js pm",
    "pm2": "node scripts/run-node20.cjs ./node_modules/@nocobase/cli/bin/index.js pm2",
    "dev": "node scripts/run-node20.cjs ./node_modules/@nocobase/cli/bin/index.js dev",
    "start": "node scripts/run-node20.cjs ./node_modules/@nocobase/cli/bin/index.js start",
    "clean": "node scripts/run-node20.cjs ./node_modules/@nocobase/cli/bin/index.js clean",
    "build": "node scripts/run-node20.cjs ./node_modules/@nocobase/cli/bin/index.js build",
    "test": "node scripts/run-node20.cjs ./node_modules/@nocobase/cli/bin/index.js test",
    "e2e": "node scripts/run-node20.cjs ./node_modules/@nocobase/cli/bin/index.js e2e",
    "tar": "node scripts/run-node20.cjs ./node_modules/@nocobase/cli/bin/index.js tar",
    "postinstall": "node scripts/run-node20.cjs ./node_modules/@nocobase/cli/bin/index.js postinstall",
    "lint": "eslint .",
    "typecheck:datasource-mirror": "node scripts/run-node20.cjs ./node_modules/typescript/bin/tsc -p packages/plugins/@my-project/plugin-datasource-mirror/tsconfig.json --noEmit",
    "test:datasource-mirror": "node scripts/run-node20.cjs ./scripts/test-datasource-mirror-integration.cjs"
  },
  "resolutions": {
    "cytoscape": "3.28.0",
    "@types/react": "18.3.18",
    "@types/react-dom": "^18.0.0",
    "react-router-dom": "^6.30.1",
    "react-router": "^6.30.1",
    "antd": "5.24.2",
    "async": "^3.2.6",
    "rollup": "4.24.0",
    "semver": "^7.7.1"
  },
  "dependencies": {
    "pm2": "^6.0.5",
    "mysql2": "^3.14.0",
    "mariadb": "^2.5.6",
    "pg": "^8.14.1",
    "pg-hstore": "^2.3.4",
    "@nocobase/cli": "2.1.0-beta.10"
  },
  "devDependencies": {
    "@nocobase/devtools": "2.1.0-beta.10"
  }
}
